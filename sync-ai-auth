#!/bin/bash
# sync-ai-auth - Sync OpenAI OAuth ke OMP dan Pi sekaligus
# Usage: sync-ai-auth [opencode|codex|cockpit] [--yes] [--status] [--only omp|pi]

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/lib/jwt-helpers.sh"
source "$SCRIPT_DIR/lib/account-sources.sh"

OMP_DB="$HOME/.omp/agent/agent.db"
PI_AUTH="$HOME/.pi/agent/auth.json"
OPENCODE_AUTH="$HOME/.local/share/opencode/auth.json"
CODEX_AUTH="$HOME/.codex/auth.json"
COCKPIT_CURRENT="$HOME/.antigravity_cockpit/provider_current_accounts.json"
COCKPIT_CODEX_ACCOUNTS="$HOME/.antigravity_cockpit/codex_accounts"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
DIM='\033[2m'
NC='\033[0m'

info()  { echo -e "${GREEN}[OK]${NC} $*"; }
warn()  { echo -e "${YELLOW}[!]${NC} $*"; }
err()   { echo -e "${RED}[ERR]${NC} $*" >&2; }

check_deps() {
    for cmd in python3 jq; do
        if ! command -v "$cmd" &>/dev/null; then
            err "Butuh '$cmd' tapi belum terinstall."
            exit 1
        fi
    done
}

write_to_omp() {
    if [[ ! -f "$OMP_DB" ]]; then
        warn "OMP DB tidak ditemukan, skip."
        return 1
    fi

    python3 "$SCRIPT_DIR/lib/vault_backends.py" write-omp \
        --db "$OMP_DB" \
        --access "$ACCESS_TOKEN" \
        --refresh "$REFRESH_TOKEN" \
        --expires "$EXPIRES" \
        --account-id "$ACCOUNT_ID" \
        --email "$EMAIL" \
        --replaced-by "sync-ai-auth"
}

write_to_pi() {
    local pi_dir
    pi_dir=$(dirname "$PI_AUTH")
    if [[ ! -d "$pi_dir" ]]; then
        warn "Pi directory tidak ditemukan, skip."
        return 1
    fi

    python3 "$SCRIPT_DIR/lib/vault_backends.py" write-pi \
        --path "$PI_AUTH" \
        --access "$ACCESS_TOKEN" \
        --refresh "$REFRESH_TOKEN" \
        --expires "$EXPIRES" \
        --account-id "$ACCOUNT_ID"
}

show_status() {
    echo ""
    local sep="─────────────────────────────────────────────────────────"
    echo -e "  ${DIM}${sep}${NC}"
    printf "  ${CYAN}%-12s${NC}  %-28s  %-8s  %s\n" "App" "Akun" "Plan" "Token"
    echo -e "  ${DIM}${sep}${NC}"

    # OMP
    local omp_info="???|???|???"
    if [[ -f "$OMP_DB" ]]; then
        local omp_token
        omp_token=$(sqlite3 "$OMP_DB" "
            SELECT json_extract(data, '$.access')
            FROM auth_credentials
            WHERE provider = 'openai-codex' AND disabled_cause IS NULL
            ORDER BY id DESC LIMIT 1;
        " 2>/dev/null || true)
        if [[ -n "$omp_token" ]]; then
            omp_info=$(jwt_info "$omp_token")
        fi
    fi
    local omp_email omp_plan omp_exp
    IFS='|' read -r omp_email omp_plan omp_exp <<< "$omp_info"
    printf "  %-12s  %-28s  %-8s  %s\n" "omp" "$omp_email" "$omp_plan" "$omp_exp"

    # Pi
    local pi_info="???|???|???"
    if [[ -f "$PI_AUTH" ]]; then
        local pi_token
        pi_token=$(jq -r '."openai-codex".access // empty' "$PI_AUTH" 2>/dev/null || true)
        if [[ -n "$pi_token" ]]; then
            pi_info=$(jwt_info "$pi_token")
        fi
    fi
    local pi_email pi_plan pi_exp
    IFS='|' read -r pi_email pi_plan pi_exp <<< "$pi_info"
    printf "  %-12s  %-28s  %-8s  %s\n" "pi" "$pi_email" "$pi_plan" "$pi_exp"

    # OpenCode
    local oc_info="???|???|???"
    if [[ -f "$OPENCODE_AUTH" ]]; then
        local oc_token
        oc_token=$(jq -r '.openai.access // empty' "$OPENCODE_AUTH" 2>/dev/null || true)
        if [[ -n "$oc_token" ]]; then
            oc_info=$(jwt_info "$oc_token")
        fi
    fi
    local oc_email oc_plan oc_exp
    IFS='|' read -r oc_email oc_plan oc_exp <<< "$oc_info"
    printf "  %-12s  %-28s  %-8s  %s\n" "opencode" "$oc_email" "$oc_plan" "$oc_exp"

    # Codex
    local cx_info="???|???|???"
    if [[ -f "$CODEX_AUTH" ]]; then
        local cx_token
        cx_token=$(jq -r '.tokens.access_token // empty' "$CODEX_AUTH" 2>/dev/null || true)
        if [[ -n "$cx_token" ]]; then
            cx_info=$(jwt_info "$cx_token")
        fi
    fi
    local cx_email cx_plan cx_exp
    IFS='|' read -r cx_email cx_plan cx_exp <<< "$cx_info"
    printf "  %-12s  %-28s  %-8s  %s\n" "codex" "$cx_email" "$cx_plan" "$cx_exp"

    # Qoder CLI
    local qoder_profile qoder_account
    qoder_profile=$(cat "$HOME/.qoder/.auth/profiles/.current" 2>/dev/null || echo "(none)")
    local qoder_email="(none)"
    if [[ -f "$HOME/.antigravity_cockpit/provider_current_accounts.json" ]]; then
        local qoder_id
        qoder_id=$(jq -r '.current_accounts.qoder // empty' "$HOME/.antigravity_cockpit/provider_current_accounts.json" 2>/dev/null || true)
        if [[ -n "$qoder_id" ]]; then
            qoder_email=$(jq -r '.email // "?"' "$HOME/.antigravity_cockpit/qoder_accounts/${qoder_id}.json" 2>/dev/null || echo "?")
        fi
    fi
    printf "  %-12s  %-28s  %-8s  %s\n" "qodercli" "$qoder_email" "(cockpit)" "profile: $qoder_profile"

    echo -e "  ${DIM}${sep}${NC}"

    # Sync check (OpenAI apps only)
    local all_emails=("$omp_email" "$pi_email" "$oc_email" "$cx_email")
    local unique_emails
    unique_emails=$(printf '%s\n' "${all_emails[@]}" | grep -v '?' | sort -u | wc -l)
    if [[ "$unique_emails" -le 1 && "$unique_emails" -gt 0 ]]; then
        echo -e "  ${GREEN}OpenAI apps (omp, pi, opencode, codex) pakai akun yang sama${NC}"
    elif [[ "$unique_emails" -gt 1 ]]; then
        echo -e "  ${YELLOW}Ada akun OpenAI yang berbeda antar app${NC}"
    fi

    # Qoder CLI sync hint
    if [[ "$qoder_email" != "(none)" && "$qoder_email" != "?" ]]; then
        echo -e "  ${DIM}Qoder CLI: swap profile pakai 'qoder-auth-swap use <nama>'${NC}"
    fi
    echo ""
}

main() {
    echo -e "${CYAN}=== Sync AI Auth (OMP + Pi) ===${NC}"
    echo ""

    check_deps

    local auto_yes=false
    local status_only=false
    local only_target=""
    local mode="auto"

    local args=()
    for arg in "$@"; do
        case "$arg" in
            -y|--yes) auto_yes=true ;;
            -s|--status) status_only=true ;;
            --only) ;;
            omp|pi)
                if [[ "${args[-1]:-}" == "--only" ]]; then
                    only_target="$arg"
                else
                    args+=("$arg")
                fi
                ;;
            opencode|codex|cockpit) mode="$arg" ;;
            -h|--help)
                echo "Usage: sync-ai-auth [opencode|codex|cockpit] [--yes] [--status] [--only omp|pi]"
                echo ""
                echo "Sync OpenAI OAuth ke OMP dan Pi sekaligus dalam satu kali jalan."
                echo ""
                echo "Sources:"
                echo "  opencode  Ambil auth dari OpenCode"
                echo "  codex     Ambil auth dari Codex CLI"
                echo "  cockpit   Ambil auth dari Cockpit Tools (akun Codex aktif)"
                echo "  auto      Coba opencode > codex > cockpit (default)"
                echo ""
                echo "Flags:"
                echo "  -y, --yes       Skip konfirmasi"
                echo "  -s, --status    Tampilkan status saja"
                echo "  --only omp|pi   Sync ke satu target saja"
                exit 0
                ;;
            *) args+=("$arg") ;;
        esac
    done

    if [[ "$status_only" == "true" ]]; then
        show_status
        exit 0
    fi

    local loaded=false
    case "$mode" in
        opencode) read_source_opencode && loaded=true ;;
        codex)    read_source_codex && loaded=true ;;
        cockpit)  read_source_cockpit && loaded=true ;;
        auto)
            read_source_opencode && loaded=true \
            || { read_source_codex && loaded=true; } \
            || { read_source_cockpit && loaded=true; }
            ;;
    esac

    if [[ "$loaded" != "true" ]]; then
        err "Tidak ada sumber auth yang ditemukan."
        exit 1
    fi

    local plan
    plan=$(jwt_plan "$ACCESS_TOKEN")

    info "Sumber: $SOURCE"
    info "Email:  ${EMAIL:-?}"
    info "Plan:   ${plan:-?}"

    show_status

    local targets=()
    if [[ -z "$only_target" || "$only_target" == "omp" ]]; then
        if [[ -f "$OMP_DB" ]]; then targets+=("OMP"); fi
    fi
    if [[ -z "$only_target" || "$only_target" == "pi" ]]; then
        if [[ -d "$(dirname "$PI_AUTH")" ]]; then targets+=("Pi"); fi
    fi

    if [[ ${#targets[@]} -eq 0 ]]; then
        err "Tidak ada target yang tersedia (OMP DB / Pi directory)."
        exit 1
    fi

    local target_str
    target_str=$(IFS=' + '; echo "${targets[*]}")

    if [[ "$auto_yes" != "true" ]]; then
        echo -e "${YELLOW}Timpa auth ${target_str} dengan akun ini? [y/N]${NC}"
        read -r confirm
        if [[ "$confirm" != "y" && "$confirm" != "Y" ]]; then
            warn "Dibatalkan."
            exit 0
        fi
    fi

    local synced=()
    for target in "${targets[@]}"; do
        case "$target" in
            OMP)
                if write_to_omp; then
                    info "OMP berhasil ditimpa -> ${EMAIL}"
                    synced+=("omp")
                else
                    warn "OMP gagal ditimpa"
                fi
                ;;
            Pi)
                if write_to_pi; then
                    info "Pi berhasil ditimpa -> ${EMAIL}"
                    synced+=("pi")
                else
                    warn "Pi gagal ditimpa"
                fi
                ;;
        esac
    done

    echo ""
    if [[ ${#synced[@]} -gt 0 ]]; then
        echo -e "${GREEN}Selesai! Restart app untuk pakai akun baru.${NC}"
        for s in "${synced[@]}"; do
            echo -e "  ${CYAN}${s}${NC}"
        done
    else
        err "Tidak ada target yang berhasil di-sync."
        exit 1
    fi
}

main "$@"
