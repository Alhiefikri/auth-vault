# === SWITCH OPENAI ACCOUNT ===
switch_openai() {
    header
    echo -e "  ${B}рҹ”„ Switch Akun OpenAI (OMP + Pi)${N}"
    echo ""

    local profiles=()
    for f in "$VAULT_OPENAI"/*.json; do
        [[ -f "$f" ]] || continue
        local n; n=$(basename "$f" .json)
        local e; e=$(jq -r '.email // "?"' "$f" 2>/dev/null)
        local p; p=$(jq -r '.plan // "?"' "$f" 2>/dev/null)
        profiles+=("$n  |  $e  |  $p")
    done

    if [[ ${#profiles[@]} -eq 0 ]]; then
        echo -e "  ${Y}Belum ada profile OpenAI tersimpan.${N}"
        echo -e "  ${D}Tambah dulu: menu 'Simpan Akun OpenAI'${N}"
        press_enter; return
    fi

    local chosen
    chosen=$(printf '%s\n' "${profiles[@]}" | fzf --prompt="  Pilih akun > " --height=15 --reverse 2>/dev/null) || return
    local profile_name="${chosen%% *}"
    local profile_file="$VAULT_OPENAI/${profile_name}.json"

    local access refresh expires account_id email
    access=$(jq -r '.access' "$profile_file")
    refresh=$(jq -r '.refresh' "$profile_file")
    expires=$(jq -r '.expires' "$profile_file")
    account_id=$(jq -r '.accountId // ""' "$profile_file")
    email=$(jq -r '.email' "$profile_file")

    echo ""
    echo -e "  ${G}Akun:${N} $email ($(jq -r '.plan' "$profile_file"))"
    echo ""
    echo -e "  ${Y}Apply ke:${N}"

    local targets=("omp + pi" "omp saja" "pi saja")
    local target
    target=$(printf '%s\n' "${targets[@]}" | fzf --prompt="  Target > " --height=8 --reverse 2>/dev/null) || return

    local now; now=$(date +%s)
    local done_targets=()

    case "$target" in
        *"omp + pi"*|"omp"*)
            # Write to OMP
            if [[ -f "$OMP_DB" ]]; then
                OMP_DB="$OMP_DB" _A="$access" _R="$refresh" _E="$expires" _AI="$account_id" _EM="$email" _IK="email:$email" _N="$now" \
                python3 -c "
import json, sqlite3, os
db=os.environ['OMP_DB']
data=json.dumps({'access':os.environ['_A'],'refresh':os.environ['_R'],'expires':int(os.environ['_E']),'accountId':os.environ['_AI'],'email':os.environ['_EM']})
ik=os.environ['_IK']; now=int(os.environ['_N'])
c=sqlite3.connect(db); cur=c.cursor()
cur.execute('UPDATE auth_credentials SET disabled_cause=\"replaced by auth-vault\", updated_at=? WHERE provider=\"openai-codex\" AND disabled_cause IS NULL',(now,))
cur.execute('INSERT INTO auth_credentials (provider,credential_type,data,identity_key,created_at,updated_at) VALUES (\"openai-codex\",\"oauth\",?,?,?)',(data,ik,now,now))
c.commit(); c.close()
" 2>/dev/null && done_targets+=("omp")
            fi
            # Write to Pi
            if [[ -d "$(dirname "$PI_AUTH")" ]]; then
                _A="$access" _R="$refresh" _E="$expires" _AI="$account_id" _PA="$PI_AUTH" \
                python3 -c "
import json, os
p=os.environ['_PA']
ex={}
try:
    with open(p) as f: ex=json.load(f)
except: pass
ex['openai-codex']={'type':'oauth','access':os.environ['_A'],'refresh':os.environ['_R'],'expires':int(os.environ['_E']),'accountId':os.environ['_AI']}
with open(p,'w') as f: json.dump(ex,f,indent=2); f.write('\n')
" 2>/dev/null && done_targets+=("pi")
            fi
            ;;
        *"pi"*)
            if [[ -d "$(dirname "$PI_AUTH")" ]]; then
                _A="$access" _R="$refresh" _E="$expires" _AI="$account_id" _PA="$PI_AUTH" \
                python3 -c "
import json, os
p=os.environ['_PA']
ex={}
try:
    with open(p) as f: ex=json.load(f)
except: pass
ex['openai-codex']={'type':'oauth','access':os.environ['_A'],'refresh':os.environ['_R'],'expires':int(os.environ['_E']),'accountId':os.environ['_AI']}
with open(p,'w') as f: json.dump(ex,f,indent=2); f.write('\n')
" 2>/dev/null && done_targets+=("pi")
            fi
            ;;
    esac

    echo ""
    if [[ ${#done_targets[@]} -gt 0 ]]; then
        local joined; joined=$(IFS=' + '; echo "${done_targets[*]}")
        echo -e "  ${G}вң“ Applied ke: $joined${N}"
        echo -e "  ${D}Restart app untuk pakai akun baru.${N}"
    else
        echo -e "  ${R}Gagal apply.${N}"
    fi
    press_enter
}

# === SWITCH QODER ACCOUNT ===
switch_qoder() {
    header
    echo -e "  ${B}рҹ”‘ Switch Qoder CLI${N}"
    echo ""

    local profiles=()
    for f in "$VAULT_QODER"/*; do
        [[ -f "$f" ]] || continue
        local bn; bn=$(basename "$f")
        [[ "$bn" == ".current" || "$bn" == *.meta.json ]] && continue
        profiles+=("$bn")
    done

    if [[ ${#profiles[@]} -eq 0 ]]; then
        echo -e "  ${Y}Belum ada profile Qoder tersimpan.${N}"
        echo -e "  ${D}Tambah: login dulu (qodercli login), lalu 'Simpan Akun Qoder'${N}"
        press_enter; return
    fi

    local current; current=$(cat "$VAULT_QODER/.current" 2>/dev/null || echo "")

    local display=()
    for p in "${profiles[@]}"; do
        local email="?"
        if [[ -f "$VAULT_QODER/${p}.meta.json" ]]; then
            email=$(jq -r '.email // "?"' "$VAULT_QODER/${p}.meta.json" 2>/dev/null)
        fi
        local marker=""
        [[ "$p" == "$current" ]] && marker="  вҶҗ aktif"
        display+=("$p  |  $email$marker")
    done

    local chosen
    chosen=$(printf '%s\n' "${display[@]}" | fzf --prompt="  Pilih profile > " --height=15 --reverse 2>/dev/null) || return
    local profile_name="${chosen%% *}"

    # Backup current
    [[ -f "$QODER_AUTH" ]] && cp "$QODER_AUTH" "$QODER_AUTH.bak"

    cp "$VAULT_QODER/$profile_name" "$QODER_AUTH"
    echo "$profile_name" > "$VAULT_QODER/.current"

    echo ""
    echo -e "  ${G}вң“ Qoder CLI diganti ke '$profile_name'!${N}"
    echo -e "  ${D}Restart qodercli untuk pakai akun baru.${N}"
    press_enter
}

# === DELETE ACCOUNT ===
delete_account() {
    header
    echo -e "  ${B}рҹ—‘пёҸ  Hapus Akun${N}"
    echo ""

    local all=()
    for f in "$VAULT_OPENAI"/*.json; do
        [[ -f "$f" ]] || continue
        local n; n=$(basename "$f" .json)
        local e; e=$(jq -r '.email // "?"' "$f" 2>/dev/null)
        all+=("[OpenAI] $n  |  $e")
    done
    for f in "$VAULT_QODER"/*; do
        [[ -f "$f" ]] || continue
        local bn; bn=$(basename "$f")
        [[ "$bn" == ".current" || "$bn" == *.meta.json ]] && continue
        local email="?"
        [[ -f "$VAULT_QODER/${bn}.meta.json" ]] && email=$(jq -r '.email // "?"' "$VAULT_QODER/${bn}.meta.json" 2>/dev/null)
        all+=("[Qoder]  $bn  |  $email")
    done

    if [[ ${#all[@]} -eq 0 ]]; then
        echo -e "  ${D}Tidak ada akun tersimpan.${N}"
        press_enter; return
    fi

    local chosen
    chosen=$(printf '%s\n' "${all[@]}" | fzf --prompt="  Hapus > " --height=15 --reverse 2>/dev/null) || return

    echo ""
    echo -e "  ${R}Hapus: $chosen${N}"
    echo -e "  ${Y}Yakin? [y/N]${N}"
    read -r confirm
    if [[ "$confirm" == "y" || "$confirm" == "Y" ]]; then
        if [[ "$chosen" == "[OpenAI]"* ]]; then
            local name="${chosen#*] }"; name="${name%% *}"
            rm -f "$VAULT_OPENAI/${name}.json"
            echo -e "  ${G}вң“ Profile OpenAI '$name' dihapus.${N}"
        else
            local name="${chosen#*] }"; name="${name%% *}"
            rm -f "$VAULT_QODER/$name" "$VAULT_QODER/${name}.meta.json"
            [[ "$(cat "$VAULT_QODER/.current" 2>/dev/null)" == "$name" ]] && rm -f "$VAULT_QODER/.current"
            echo -e "  ${G}вң“ Profile Qoder '$name' dihapus.${N}"
        fi
    else
        echo -e "  ${D}Dibatalkan.${N}"
    fi
    press_enter
}

# === MAIN MENU ===
main() {
    while true; do
        dashboard

        local choice
        choice=$(printf '%s\n' \
            "рҹ”„  Switch OpenAI (OMP + Pi)" \
            "рҹ”‘  Switch Qoder CLI" \
            "вһ•  Simpan Akun OpenAI" \
            "вһ•  Simpan Akun Qoder CLI" \
            "рҹ—‘пёҸ  Hapus Akun" \
            "вқҢ  Keluar" \
            | fzf --prompt="  Pilih > " --height=12 --reverse --header="  вҶ‘вҶ“ navigate, Enter select" 2>/dev/null) || exit 0

        case "$choice" in
            *"Switch OpenAI"*) switch_openai ;;
            *"Switch Qoder"*) switch_qoder ;;
            *"Simpan Akun OpenAI"*) save_openai ;;
            *"Simpan Akun Qoder"*) save_qoder ;;
            *"Hapus"*) delete_account ;;
            *"Keluar"*) echo -e "${D}Bye!${N}"; exit 0 ;;
            *) exit 0 ;;
        esac
    done
}

main "$@"
