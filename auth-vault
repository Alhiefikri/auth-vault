# Responsive resize handling: trap SIGWINCH and set flag
_NEED_REDRAW=0
trap '_NEED_REDRAW=1' WINCH

# read_input VARNAME
# Like `read -r`, but returns 2 if terminal was resized during read.
# Caller should redraw and re-prompt when return code is 2.
read_input() {
    local __varname="$1"
    _NEED_REDRAW=0
    local rc=0
    read -r "$__varname" || rc=$?
    if (( rc != 0 && _NEED_REDRAW )); then
        clear
        return 2
    elif (( _NEED_REDRAW )); then
        clear
        return 2
    fi
    return 0
}

SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
