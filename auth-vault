usage_bar() {
    local pct=$1
    local width=${2:-10}
    local filled=$(( pct * width / 100 ))
    local empty=$(( width - filled ))
    local color="$G"
    [[ $pct -ge 60 ]] && color="$Y"
    [[ $pct -ge 85 ]] && color="$R"
    local bar=""
    for ((i=0; i<filled; i++)); do bar+="в–Ҳ"; done
    for ((i=0; i<empty; i++)); do bar+="в–‘"; done
    echo -e "${color}${bar}${N} ${pct}%"
}

get_codex_usage() {
    local email="$1"
    [[ "$email" == "?" ]] && { echo "?|?"; return; }
    for f in "$COCKPIT_CODEX_ACCOUNTS"/codex_*.json; do
        [[ -f "$f" ]] || continue
        local femail; femail=$(jq -r '.email // ""' "$f" 2>/dev/null)
        if [[ "$femail" == "$email" ]]; then
            local h; h=$(jq -r '.quota.hourly_percentage // "?"' "$f" 2>/dev/null)
            local w; w=$(jq -r '.quota.weekly_percentage // "?"' "$f" 2>/dev/null)
            echo "${h}|${w}"
            return
        fi
    done
    echo "?|?"
}

get_qoder_usage() {
    local email="$1"
    [[ "$email" == "?" || "$email" == "(none)" ]] && { echo "?"; return; }
    for f in "$COCKPIT_QODER_ACCOUNTS"/qoder_uid_*.json; do
        [[ -f "$f" ]] || continue
        local femail; femail=$(jq -r '.email // ""' "$f" 2>/dev/null)
        if [[ "$femail" == "$email" ]]; then
            local pct; pct=$(jq -r '.credits_usage_percent // 0' "$f" 2>/dev/null)
            local used; used=$(jq -r '.credits_used // 0' "$f" 2>/dev/null)
            local total; total=$(jq -r '.credits_total // 0' "$f" 2>/dev/null)
            local remain; remain=$(jq -r '.credits_remaining // 0' "$f" 2>/dev/null)
            echo "${pct}|${used}|${total}|${remain}"
            return
        fi
    done
    echo "?|?|?|?"
}

# === DASHBOARD ===
dashboard() {
    header
    echo -e "  ${B}рҹ“Ҡ DASHBOARD${N}"
    echo ""
    sep
    printf "  ${C}%-11s${N}  %-28s  %-6s  %-5s  %s\n" "App" "Akun" "Plan" "Token" "Usage"
    sep

    # OMP
    local omp_email="?" omp_plan="?" omp_exp="?"
    if [[ -f "$OMP_DB" ]]; then
        local t; t=$(sqlite3 "$OMP_DB" "SELECT json_extract(data,'$.access') FROM auth_credentials WHERE provider='openai-codex' AND disabled_cause IS NULL ORDER BY id DESC LIMIT 1;" 2>/dev/null || true)
        if [[ -n "$t" ]]; then omp_email=$(jwt_email "$t"); omp_plan=$(jwt_plan "$t"); omp_exp=$(jwt_exp_days "$t"); fi
    fi
    local omp_usage; omp_usage=$(get_codex_usage "$omp_email")
    local omp_h="${omp_usage%%|*}"; omp_w="${omp_usage##*|}"
    local omp_bar=""
    if [[ "$omp_h" != "?" ]]; then
        omp_bar="h:$(usage_bar $omp_h 8) w:$(usage_bar $omp_w 8)"
    fi
    printf "  %-11s  %-28s  %-6s  %-5s  %b\n" "omp" "$omp_email" "$omp_plan" "$omp_exp" "$omp_bar"

    # Pi
    local pi_email="?" pi_plan="?" pi_exp="?"
    if [[ -f "$PI_AUTH" ]]; then
        local t; t=$(jq -r '."openai-codex".access // empty' "$PI_AUTH" 2>/dev/null || true)
        if [[ -n "$t" ]]; then pi_email=$(jwt_email "$t"); pi_plan=$(jwt_plan "$t"); pi_exp=$(jwt_exp_days "$t"); fi
    fi
    local pi_usage; pi_usage=$(get_codex_usage "$pi_email")
    local pi_h="${pi_usage%%|*}"; pi_w="${pi_usage##*|}"
    local pi_bar=""
    if [[ "$pi_h" != "?" ]]; then
        pi_bar="h:$(usage_bar $pi_h 8) w:$(usage_bar $pi_w 8)"
    fi
    printf "  %-11s  %-28s  %-6s  %-5s  %b\n" "pi" "$pi_email" "$pi_plan" "$pi_exp" "$pi_bar"

    # OpenCode
    local oc_email="?" oc_plan="?" oc_exp="?"
    if [[ -f "$OPENCODE_AUTH" ]]; then
        local t; t=$(jq -r '.openai.access // empty' "$OPENCODE_AUTH" 2>/dev/null || true)
        if [[ -n "$t" ]]; then oc_email=$(jwt_email "$t"); oc_plan=$(jwt_plan "$t"); oc_exp=$(jwt_exp_days "$t"); fi
    fi
    local oc_usage; oc_usage=$(get_codex_usage "$oc_email")
    local oc_h="${oc_usage%%|*}"; oc_w="${oc_usage##*|}"
    local oc_bar=""
    if [[ "$oc_h" != "?" ]]; then
        oc_bar="h:$(usage_bar $oc_h 8) w:$(usage_bar $oc_w 8)"
    fi
    printf "  %-11s  %-28s  %-6s  %-5s  %b\n" "opencode" "$oc_email" "$oc_plan" "$oc_exp" "$oc_bar"

    # Codex
    local cx_email="?" cx_plan="?" cx_exp="?"
    if [[ -f "$CODEX_AUTH" ]]; then
        local t; t=$(jq -r '.tokens.access_token // empty' "$CODEX_AUTH" 2>/dev/null || true)
        if [[ -n "$t" ]]; then cx_email=$(jwt_email "$t"); cx_plan=$(jwt_plan "$t"); cx_exp=$(jwt_exp_days "$t"); fi
    fi
    local cx_usage; cx_usage=$(get_codex_usage "$cx_email")
    local cx_h="${cx_usage%%|*}"; cx_w="${cx_usage##*|}"
    local cx_bar=""
    if [[ "$cx_h" != "?" ]]; then
        cx_bar="h:$(usage_bar $cx_h 8) w:$(usage_bar $cx_w 8)"
    fi
    printf "  %-11s  %-28s  %-6s  %-5s  %b\n" "codex" "$cx_email" "$cx_plan" "$cx_exp" "$cx_bar"

    # Qoder CLI
    local q_profile="(none)" q_email="?"
    q_profile=$(cat "$VAULT_QODER/.current" 2>/dev/null || echo "(none)")
    if [[ -f "$COCKPIT_CURRENT" ]]; then
        local qid; qid=$(jq -r '.current_accounts.qoder // empty' "$COCKPIT_CURRENT" 2>/dev/null || true)
        if [[ -n "$qid" ]]; then q_email=$(jq -r '.email // "?"' "$COCKPIT_QODER_ACCOUNTS/${qid}.json" 2>/dev/null || echo "?"); fi
    fi
    local q_plan="?"
    if [[ "$q_email" != "?" ]]; then
        for f in "$COCKPIT_QODER_ACCOUNTS"/qoder_uid_*.json; do
            [[ -f "$f" ]] || continue
            local fe; fe=$(jq -r '.email // ""' "$f" 2>/dev/null)
            if [[ "$fe" == "$q_email" ]]; then q_plan=$(jq -r '.plan_type // "?"' "$f" 2>/dev/null); break; fi
        done
    fi
    local q_usage; q_usage=$(get_qoder_usage "$q_email")
    local q_pct="${q_usage%%|*}"
    local q_bar=""
    if [[ "$q_pct" != "?" ]]; then
        local q_remain; q_remain=$(echo "$q_usage" | cut -d'|' -f4)
        local q_total; q_total=$(echo "$q_usage" | cut -d'|' -f3)
        local q_pct_int=${q_pct%.*}
        q_bar="cr:$(usage_bar $q_pct_int 8) ${q_remain}/${q_total}"
    fi
    printf "  %-11s  %-28s  %-6s  %-5s  %b\n" "qodercli" "$q_email" "$q_plan" "p:$q_profile" "$q_bar"

    sep

    # Sync status
    local emails=("$omp_email" "$pi_email" "$oc_email" "$cx_email")
    local uniq; uniq=$(printf '%s\n' "${emails[@]}" | grep -v '?' | sort -u | wc -l)
    if [[ "$uniq" -le 1 && "$uniq" -gt 0 ]]; then
        echo -e "  ${G}вң“ OpenAI apps sync${N}"
    elif [[ "$uniq" -gt 1 ]]; then
        echo -e "  ${Y}вҡ  OpenAI apps beda akun${N}"
    fi

    # Vault stats
    local oc; oc=$(find "$VAULT_OPENAI" -maxdepth 1 -type f -name '*.json' 2>/dev/null | wc -l)
    local qc; qc=$(find "$VAULT_QODER" -maxdepth 1 -type f ! -name '.current' ! -name '*.meta.json' 2>/dev/null | wc -l)
    echo -e "  ${D}Vault: ${oc} OpenAI + ${qc} Qoder profiles${N}"
    echo ""
}

# === SAVE OPENAI ACCOUNT ===
save_openai() {
    header
    echo -e "  ${B}вһ• Simpan Akun OpenAI${N}"
    echo ""
    echo -e "  ${D}Pilih sumber:${N}"
    echo ""

    local sources=()
    [[ -f "$OPENCODE_AUTH" ]] && sources+=("opencode  вҶ’ $(jq -r '.openai.access // empty' "$OPENCODE_AUTH" 2>/dev/null | { read -r t; [[ -n "$t" ]] && jwt_email "$t" || echo "?"; })")
    [[ -f "$CODEX_AUTH" ]] && sources+=("codex     вҶ’ $(jq -r '.tokens.access_token // empty' "$CODEX_AUTH" 2>/dev/null | { read -r t; [[ -n "$t" ]] && jwt_email "$t" || echo "?"; })")

    if [[ ${#sources[@]} -eq 0 ]]; then
        echo -e "  ${R}Tidak ada sumber auth OpenAI yang ditemukan.${N}"
        press_enter; return
    fi

    local src
    src=$(printf '%s\n' "${sources[@]}" | fzf --prompt="  Pilih sumber > " --height=10 --reverse 2>/dev/null) || return
    local source_type="${src%% *}"

    local access="" refresh="" expires="" account_id="" email=""
    case "$source_type" in
        opencode)
            access=$(jq -r '.openai.access' "$OPENCODE_AUTH")
            refresh=$(jq -r '.openai.refresh' "$OPENCODE_AUTH")
            expires=$(jq -r '.openai.expires' "$OPENCODE_AUTH")
            account_id=$(jq -r '.openai.accountId // ""' "$OPENCODE_AUTH")
            email=$(jwt_email "$access")
            ;;
        codex)
            access=$(jq -r '.tokens.access_token' "$CODEX_AUTH")
            refresh=$(jq -r '.tokens.refresh_token' "$CODEX_AUTH")
            local p; p=$(jwt_decode "$access")
            expires=$(( $(echo "$p" | jq -r '.exp // 0' 2>/dev/null) * 1000 ))
            account_id=$(jq -r '.tokens.account_id // ""' "$CODEX_AUTH")
            email=$(jwt_email "$access")
            ;;
    esac

    echo ""
    echo -e "  ${G}Sumber:${N} $source_type"
    echo -e "  ${G}Email:${N}  $email"
    echo -e "  ${G}Plan:${N}   $(jwt_plan "$access")"
    echo ""

    local name
    echo -e "  ${Y}Nama profile (contoh: akun-utama):${N}"
    read -r -p "  > " name
    [[ -z "$name" ]] && { echo -e "  ${R}Dibatalkan.${N}"; press_enter; return; }

    python3 -c "
import json, sys
d = {
    'name': sys.argv[1],
    'email': sys.argv[2],
    'plan': sys.argv[3],
    'source': sys.argv[4],
    'access': sys.argv[5],
    'refresh': sys.argv[6],
    'expires': int(sys.argv[7]),
    'accountId': sys.argv[8],
    'saved_at': $(date +%s)
}
with open(sys.argv[9], 'w') as f:
    json.dump(d, f, indent=2)
    f.write('\n')
" "$name" "$email" "$(jwt_plan "$access")" "$source_type" "$access" "$refresh" "$expires" "$account_id" "$VAULT_OPENAI/${name}.json"

    echo -e "  ${G}вң“ Profile '$name' disimpan!${N}"
    press_enter
}

# === SAVE QODER ACCOUNT ===
save_qoder() {
