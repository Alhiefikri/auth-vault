#!/bin/bash
# Auth Vault - TUI Credential Manager for AI Coding Tools
# Cockpit Tools integration: reads accounts from Cockpit, applies to OMP/Pi/Qoder
set -euo pipefail

VAULT_DIR="$HOME/.auth-vault/qoder"
QODER_AUTH="$HOME/.qoder/.auth/user"
OLD_PROFILES_DIR="$HOME/.qoder/.auth/profiles"
OMP_DB="$HOME/.omp/agent/agent.db"
PI_AUTH="$HOME/.pi/agent/auth.json"
OPENCODE_AUTH="$HOME/.local/share/opencode/auth.json"
CODEX_AUTH="$HOME/.codex/auth.json"
COCKPIT_CURRENT="$HOME/.antigravity_cockpit/provider_current_accounts.json"
COCKPIT_CODEX_ACCOUNTS="$HOME/.antigravity_cockpit/codex_accounts"
COCKPIT_QODER_ACCOUNTS="$HOME/.antigravity_cockpit/qoder_accounts"
COCKPIT_ACCOUNTS="$HOME/.antigravity_cockpit/accounts.json"

R='\033[0;31m'; G='\033[0;32m'; Y='\033[1;33m'; C='\033[0;36m'
B='\033[1m'; D='\033[2m'; N='\033[0m'

SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
source "$SCRIPT_DIR/lib/vault-profiles.sh"
source "$SCRIPT_DIR/lib/jwt-helpers.sh"
source "$SCRIPT_DIR/lib/find-autologin.sh"
source "$SCRIPT_DIR/lib/ui-helpers.sh"
vault_ensure_dir
vault_migrate

