# === COCKPIT HELPERS ===
get_current_codex_id() { [[ -f "$COCKPIT_CURRENT" ]] || { echo ""; return; }; jq -r '.current_accounts.codex // empty' "$COCKPIT_CURRENT" 2>/dev/null || echo ""; }
get_current_qoder_id() { [[ -f "$COCKPIT_CURRENT" ]] || { echo ""; return; }; jq -r '.current_accounts.qoder // empty' "$COCKPIT_CURRENT" 2>/dev/null || echo ""; }
get_codex_usage() {
    local email="$1"; [[ "$email" == "?" ]] && { echo "?|?"; return; }
    for f in "$COCKPIT_CODEX_ACCOUNTS"/codex_*.json; do
        [[ -f "$f" ]] || continue
        local femail; femail=$(jq -r '.email // ""' "$f" 2>/dev/null)
        if [[ "$femail" == "$email" ]]; then
            echo "$(jq -r '.quota.hourly_percentage // "?"' "$f" 2>/dev/null)|$(jq -r '.quota.weekly_percentage // "?"' "$f" 2>/dev/null)"
            return
        fi
    done
    echo "?|?"
}
get_qoder_usage() {
    local email="$1"; [[ "$email" == "?" || "$email" == "(none)" ]] && { echo "?"; return; }
    for f in "$COCKPIT_QODER_ACCOUNTS"/qoder_uid_*.json; do
        [[ -f "$f" ]] || continue
        local femail; femail=$(jq -r '.email // ""' "$f" 2>/dev/null)
        if [[ "$femail" == "$email" ]]; then
            echo "$(jq -r '.credits_usage_percent // 0' "$f" 2>/dev/null)|$(jq -r '.credits_used // 0' "$f" 2>/dev/null)|$(jq -r '.credits_total // 0' "$f" 2>/dev/null)|$(jq -r '.credits_remaining // 0' "$f" 2>/dev/null)"
            return
        fi
    done
    echo "?|?|?|?"
}
is_account_active() {
    local email="$1"
    [[ -f "$COCKPIT_ACCOUNTS" ]] || return 0
    local result
    result=$(jq -r --arg e "$email" '.accounts[] | select(.email == $e) | .email' "$COCKPIT_ACCOUNTS" 2>/dev/null)
    [[ -n "$result" ]]
}
is_qoder_account_active() {
    local email="$1"
    local qjson="$HOME/.antigravity_cockpit/qoder_accounts.json"
    [[ -f "$qjson" ]] || return 0
    local result
    result=$(jq -r --arg e "$email" '.accounts[] | select(.email == $e) | .email' "$qjson" 2>/dev/null)
    [[ -n "$result" ]]
}

# === DASHBOARD (compact summary) ===
dashboard() {
    header
    echo -e "  ${B}📊 DASHBOARD${N}"
    echo ""
    local hl; hl=$(hline 28)
    echo -e "  ${D}┌──────────┬─${hl}─┬────────┬─────────┬───────────────────────────┐${N}"
    printf "  ${D}│${N} ${C}%-8s${N} ${D}│${N} ${C}%-28s${N} ${D}│${N} ${C}%-6s${N} ${D}│${N} ${C}%-7s${N} ${D}│${N} ${C}%-25s${N} ${D}│${N}\n" \
        "Tool" "Akun Aktif" "Plan" "Token" "Usage"
    echo -e "  ${D}├──────────┼─${hl}─┼────────┼─────────┼───────────────────────────┤${N}"

    # OpenAI row
    if [[ -d "$COCKPIT_CODEX_ACCOUNTS" ]]; then
        local cid; cid=$(get_current_codex_id)
        if [[ -n "$cid" && -f "$COCKPIT_CODEX_ACCOUNTS/${cid}.json" ]]; then
            local email; email=$(jq -r '.email // "?"' "$COCKPIT_CODEX_ACCOUNTS/${cid}.json" 2>/dev/null)
            local token; token=$(jq -r '.tokens.access_token // empty' "$COCKPIT_CODEX_ACCOUNTS/${cid}.json" 2>/dev/null)
            local plan="?" exp="?" exp_color="$D"
            [[ -n "$token" ]] && { plan=$(jwt_plan "$token"); exp=$(jwt_exp_days "$token"); }
            if [[ "$exp" == "expired" ]]; then
                exp_color="$R"
            elif [[ "$exp" =~ ^[0-9]+d$ ]]; then
                local days="${exp%d}"
                [[ $days -le 1 ]] && exp_color="$R"
                [[ $days -ge 2 && $days -le 3 ]] && exp_color="$Y"
                [[ $days -ge 4 ]] && exp_color="$G"
            fi
            local ud; ud=$(get_codex_usage "$email")
            local h="${ud%%|*}" w="${ud##*|}" bar=""
            [[ "$h" != "?" ]] && bar="h:$(remaining_bar $h 4)"
            printf "  ${D}│${N} ${G}%-8s${N} ${D}│${N} %-28s ${D}│${N} %-6s ${D}│${N} ${exp_color}%-7s${N} ${D}│${N} %b  ${D}│${N}\n" "OpenAI" "$email" "$plan" "$exp" "$bar"
        else
            printf "  ${D}│${N} %-8s ${D}│${N} ${D}%-28s${N} ${D}│${N} %-6s ${D}│${N} %-7s ${D}│${N} %-25s ${D}│${N}\n" "OpenAI" "(belum ada akun aktif)" "" "" ""
        fi
    else
        printf "  ${D}│${N} %-8s ${D}│${N} ${R}%-28s${N} ${D}│${N} %-6s ${D}│${N} %-7s ${D}│${N} %-25s ${D}│${N}\n" "OpenAI" "Cockpit tidak terdeteksi" "" "" ""
    fi

    # Qoder row
    if [[ -d "$COCKPIT_QODER_ACCOUNTS" ]]; then
        local qid; qid=$(get_current_qoder_id)
        if [[ -n "$qid" && -f "$COCKPIT_QODER_ACCOUNTS/${qid}.json" ]]; then
            local email; email=$(jq -r '.email // "?"' "$COCKPIT_QODER_ACCOUNTS/${qid}.json" 2>/dev/null)
            local plan; plan=$(jq -r '.plan_type // "?"' "$COCKPIT_QODER_ACCOUNTS/${qid}.json" 2>/dev/null)
            local ud; ud=$(get_qoder_usage "$email")
            local qp="${ud%%|*}" qbar=""
            if [[ "$qp" != "?" ]]; then
                local qr; qr=$(echo "$ud" | cut -d'|' -f4)
                local qt; qt=$(echo "$ud" | cut -d'|' -f3)
                local qpi=${qp%.*}
                qbar="cr:$(usage_bar $qpi 4) ${qr}/${qt}"
            fi
            printf "  ${D}│${N} ${C}%-8s${N} ${D}│${N} %-28s ${D}│${N} %-6s ${D}│${N} %-7s ${D}│${N} %b  ${D}│${N}\n" "Qoder" "$email" "$plan" "-" "$qbar"
        else
            printf "  ${D}│${N} %-8s ${D}│${N} ${D}%-28s${N} ${D}│${N} %-6s ${D}│${N} %-7s ${D}│${N} %-25s ${D}│${N}\n" "Qoder" "(belum ada akun aktif)" "" "" ""
        fi
    else
        printf "  ${D}│${N} %-8s ${D}│${N} ${D}%-28s${N} ${D}│${N} %-6s ${D}│${N} %-7s ${D}│${N} %-25s ${D}│${N}\n" "Qoder" "(belum ada akun)" "" "" ""
    fi

    echo -e "  ${D}└──────────┴─${hl}─┴────────┴─────────┴───────────────────────────┘${N}"
    echo ""
    echo -e "  ${D}github.com/Alhiefikri/auth-vault${N}"
    echo ""
}

# === DETAIL OPENAI (list accounts + switch) ===
detail_openai() {
    header
    echo -e "  ${B}🔗 OpenAI${N} ${D}(via Cockpit Tools)${N}"
    echo ""

    if [[ ! -d "$COCKPIT_CODEX_ACCOUNTS" ]]; then
        echo -e "  ${R}Cockpit Tools tidak ditemukan.${N}"
        press_enter || return $?; return
    fi

    local current_id; current_id=$(get_current_codex_id)
    local ids=() emails=() plans=() exps=()
    for f in "$COCKPIT_CODEX_ACCOUNTS"/codex_*.json; do
        [[ -f "$f" ]] || continue
        local fid; fid=$(basename "$f" .json)
        local email; email=$(jq -r '.email // "?"' "$f" 2>/dev/null)
        local token; token=$(jq -r '.tokens.access_token // empty' "$f" 2>/dev/null)
        local plan="?" exp="?"
        [[ -n "$token" ]] && { plan=$(jwt_plan "$token"); exp=$(jwt_exp_days "$token"); }
        ids+=("$fid"); emails+=("$email"); plans+=("$plan"); exps+=("$exp")
    done

    if [[ ${#ids[@]} -eq 0 ]]; then
        echo -e "  ${Y}Belum ada akun Codex di Cockpit.${N}"
        press_enter || return $?; return
    fi

    # Dynamic email column width: total = 71 + email_col
    local term_width=${COLUMNS:-100}
    local max_email=20
    for email in "${emails[@]}"; do
        [[ ${#email} -gt $max_email ]] && max_email=${#email}
    done
    local email_col=$(( term_width - 71 ))
    [[ $email_col -lt 20 ]] && email_col=20
    [[ $email_col -gt $max_email ]] && email_col=$max_email

    local ec_hl; ec_hl=$(hline "$email_col")
    local bars_hl; bars_hl=$(hline 33)

    # Table header
    echo ""
    echo -e "  ${D}┌─────┬─${ec_hl}─┬──────────┬─────────┬─${bars_hl}${N}"
    printf "  ${D}│${N} ${C}%2s${N}  ${D}│${N} ${C}%-${email_col}s${N} ${D}│${N} ${C}%-8s${N} ${D}│${N} ${C}%-7s${N} ${D}│${N} ${C}%s${N}\n" \
        "#" "Email" "Plan" "Expire" "Quota Remaining (h / w)"
    echo -e "  ${D}├─────┼─${ec_hl}─┼──────────┼─────────┼─${bars_hl}${N}"

    for i in "${!ids[@]}"; do
        local marker="o" mcolor="$D" ncolor="$D" ecolor="$D"
        if [[ "${ids[$i]}" == "$current_id" ]]; then
            marker="*"; mcolor="$G"; ncolor="$G"; ecolor="$G"
        elif ! is_account_active "${emails[$i]}"; then
            marker="x"; mcolor="$Y"; ncolor="$Y"; ecolor="$Y"
        fi

        local ud; ud=$(get_codex_usage "${emails[$i]}")
        local h="${ud%%|*}" w="${ud##*|}" bar=""
        if [[ "$h" != "?" ]]; then
            bar="h:$(remaining_bar $h 4)  w:$(remaining_bar $w 4)"
        else
            bar="${D}─────────────────────────────────${N}"
        fi

        # Truncate email
        local display_email="${emails[$i]}"
        [[ ${#display_email} -gt $email_col ]] && display_email="${display_email:0:$((email_col-3))}..."

        # Color-coded expiry
        local exp_display="${exps[$i]}" exp_color="$D"
        if [[ "$exp_display" == "expired" ]]; then
            exp_color="$R"
        elif [[ "$exp_display" =~ ^[0-9]+d$ ]]; then
            local days="${exp_display%d}"
            [[ $days -le 1 ]] && exp_color="$R"
            [[ $days -ge 2 && $days -le 3 ]] && exp_color="$Y"
            [[ $days -ge 4 ]] && exp_color="$G"
        fi

        printf "  ${D}│${N} ${mcolor}%s${N}${ncolor}%1s${N} ${D}│${N} ${ecolor}%-${email_col}s${N} ${D}│${N} %-8s ${D}│${N} ${exp_color}%-7s${N} ${D}│${N} %b\n" \
            "$marker" "$((i+1))" "$display_email" "${plans[$i]}" "$exp_display" "$bar"
    done
    echo -e "  ${D}└─────┴─${ec_hl}─┴──────────┴─────────┴─${bars_hl}${N}"

    # Legend
    echo ""
    echo -e "  ${G}*${N} aktif (current)   ${D}o${N} cockpit registered   ${Y}x${N} tidak di accounts.json"

    # Footer
    echo ""
    echo -e "  ${B}${#ids[@]} akun terdaftar${N}  ${D}│${N}  ${D}github.com/Alhiefikri/auth-vault${N}"
    echo ""
    echo -e "  ${Y}Switch akun [1-${#ids[@]}] atau Enter untuk batal:${N}"
    echo -n "  > "
    local pick_rc=0
    read_input pick || pick_rc=$?
    if (( pick_rc == 2 )); then return 0; fi

    if [[ -z "$pick" ]]; then return; fi
    if ! [[ "$pick" =~ ^[0-9]+$ ]] || (( pick < 1 || pick > ${#ids[@]} )); then
        echo -e "  ${R}Pilihan tidak valid.${N}"
        press_enter || return $?; return
    fi

    local idx=$(( pick - 1 ))
    local chosen_id="${ids[$idx]}"
    local chosen_file="$COCKPIT_CODEX_ACCOUNTS/${chosen_id}.json"
    local access; access=$(jq -r '.tokens.access_token' "$chosen_file")
    local refresh; refresh=$(jq -r '.tokens.refresh_token' "$chosen_file")
    local email; email=$(jq -r '.email // "?"' "$chosen_file")
    local account_id; account_id=$(jq -r '.account_id // .tokens.account_id // ""' "$chosen_file")
    local expires; expires=$(jwt_exp_ms "$access")

    echo ""
    echo -e "  ${G}Akun:${N} $email ($(jwt_plan "$access"))"
    echo -e "  ${Y}Apply ke semua app (omp, pi, opencode, codex)...${N}"

    local done_targets=()

    if [[ -f "$OMP_DB" ]]; then
        python3 "$SCRIPT_DIR/lib/vault_backends.py" write-omp \
            --db "$OMP_DB" \
            --access "$access" \
            --refresh "$refresh" \
            --expires "$expires" \
            --account-id "$account_id" \
            --email "$email" \
            --replaced-by "auth-vault" \
            2>/dev/null && done_targets+=("omp")
    fi

    if [[ -d "$(dirname "$PI_AUTH")" ]]; then
        python3 "$SCRIPT_DIR/lib/vault_backends.py" write-pi \
            --path "$PI_AUTH" \
            --access "$access" \
            --refresh "$refresh" \
            --expires "$expires" \
            --account-id "$account_id" \
            2>/dev/null && done_targets+=("pi")
    fi

    if [[ -f "$OPENCODE_AUTH" ]]; then
        python3 "$SCRIPT_DIR/lib/vault_backends.py" write-opencode \
            --path "$OPENCODE_AUTH" \
            --access "$access" \
            --refresh "$refresh" \
            --expires "$expires" \
            --account-id "$account_id" \
            2>/dev/null && done_targets+=("opencode")
    fi

    if [[ -f "$CODEX_AUTH" ]]; then
        python3 "$SCRIPT_DIR/lib/vault_backends.py" write-codex \
            --path "$CODEX_AUTH" \
            --access "$access" \
            --refresh "$refresh" \
            --expires "$expires" \
            --account-id "$account_id" \
            2>/dev/null && done_targets+=("codex")
    fi

    if [[ -f "$COCKPIT_CURRENT" ]]; then
        python3 "$SCRIPT_DIR/lib/vault_backends.py" update-cockpit-current \
            --path "$COCKPIT_CURRENT" \
            --provider "codex" \
            --account-id "$chosen_id" \
            2>/dev/null
    fi

    echo ""
    if [[ ${#done_targets[@]} -gt 0 ]]; then
        local joined; joined=$(IFS=' + '; echo "${done_targets[*]}")
        echo -e "  ${G}✓ Applied ke: $joined${N}"
        echo -e "  ${G}✓ Cockpit current updated${N}"
        echo -e "  ${D}Restart app untuk pakai akun baru.${N}"
    else
        echo -e "  ${R}Gagal apply.${N}"
    fi
    press_enter || return $?
}

# === DETAIL QODER (list accounts + switch) ===
detail_qoder() {
    header
    echo -e "  ${B}🔑 Qoder CLI${N}"
    echo ""

    if [[ -d "$COCKPIT_QODER_ACCOUNTS" ]]; then
        local current_qoder_id; current_qoder_id=$(get_current_qoder_id)
        sep
        printf "  ${C}%-4s${N}  %-28s  %-8s  %s\n" "" "Email" "Plan" "Credits"
        sep
        local count=0
        for f in "$COCKPIT_QODER_ACCOUNTS"/qoder_uid_*.json; do
            [[ -f "$f" ]] || continue
            local fid; fid=$(basename "$f" .json)
            local email; email=$(jq -r '.email // "?"' "$f" 2>/dev/null)
            is_qoder_account_active "$email" || continue
            count=$(( count + 1 ))
            local plan; plan=$(jq -r '.plan_type // "?"' "$f" 2>/dev/null)
            local marker="○" color="$D"
            [[ "$fid" == "$current_qoder_id" ]] && { marker="●"; color="$G"; }
            local ud; ud=$(get_qoder_usage "$email")
            local qp="${ud%%|*}" qbar=""
            if [[ "$qp" != "?" ]]; then
                local qr; qr=$(echo "$ud" | cut -d'|' -f4)
                local qt; qt=$(echo "$ud" | cut -d'|' -f3)
                local qpi=${qp%.*}
                qbar="cr:$(usage_bar $qpi 8) ${qr}/${qt}"
            fi
            printf "  ${color}%-4s${N}  %-28s  %-8s  %b\n" "$marker" "$email" "$plan" "$qbar"
        done
        [[ $count -eq 0 ]] && echo -e "  ${D}(belum ada akun Qoder di Cockpit)${N}"
        sep
        echo ""
    fi

    # Vault profiles
    local profiles=()
    local current_vault; current_vault=$(vault_get_current)
    while IFS= read -r pname; do
        [[ -z "$pname" ]] && continue
        profiles+=("$pname")
    done <<< "$(vault_list_names)"

    if [[ ${#profiles[@]} -gt 0 ]]; then
        echo -e "  ${B}Profile Vault:${N}"
        sep
        for i in "${!profiles[@]}"; do
            local pf="${profiles[$i]}"
            local email; email=$(vault_get_email "$pf")
            local marker="  "
            [[ "$pf" == "$current_vault" ]] && marker="→ "
            echo -e "  ${B}$(( i + 1 )).${N} ${marker}${pf}  ${D}|  $email${N}"
        done
        sep
        echo ""
        echo -e "  ${Y}Switch profile [1-${#profiles[@]}], [s] Simpan baru, atau Enter untuk batal:${N}"
    else
        echo -e "  ${D}Belum ada profile Qoder di vault.${N}"
        echo ""
        echo -e "  ${Y}[s] Simpan profile baru, atau Enter untuk batal:${N}"
    fi

    echo -n "  > "
    pick_rc=0
    read_input pick || pick_rc=$?
    if (( pick_rc == 2 )); then return 0; fi

    if [[ -z "$pick" ]]; then return; fi

    if [[ "$pick" == "s" ]]; then
        save_qoder
        return
    fi

    if [[ ${#profiles[@]} -eq 0 ]]; then
        echo -e "  ${R}Pilihan tidak valid.${N}"
        press_enter || return $?; return
    fi

    if ! [[ "$pick" =~ ^[0-9]+$ ]] || (( pick < 1 || pick > ${#profiles[@]} )); then
        echo -e "  ${R}Pilihan tidak valid.${N}"
        press_enter || return $?; return
    fi

    local idx=$(( pick - 1 ))
    local profile_name="${profiles[$idx]}"

    vault_use "$profile_name"

    echo ""
    echo -e "  ${G}✓ Qoder CLI diganti ke '$profile_name'!${N}"
    echo -e "  ${D}Restart qodercli untuk pakai akun baru.${N}"
    press_enter || return $?
}

# === SAVE QODER ===
save_qoder() {
    header
    echo -e "  ${B}➕ Simpan Akun Qoder CLI${N}"
    echo ""

    if [[ ! -f "$QODER_AUTH" ]]; then
        echo -e "  ${R}File auth Qoder CLI belum ada: $QODER_AUTH${N}"
        echo -e "  ${D}Login dulu: qodercli login${N}"
        press_enter || return $?; return
    fi

    local email="(unknown)"
    if [[ -f "$COCKPIT_CURRENT" ]]; then
        local qid; qid=$(jq -r '.current_accounts.qoder // empty' "$COCKPIT_CURRENT" 2>/dev/null || true)
        if [[ -n "$qid" ]]; then email=$(jq -r '.email // "?"' "$COCKPIT_QODER_ACCOUNTS/${qid}.json" 2>/dev/null || echo "?"); fi
    fi

    echo -e "  ${G}Auth file:${N} $QODER_AUTH"
    echo -e "  ${G}Cockpit:${N}   $email"
    echo ""

    local name
    echo -e "  ${Y}Nama profile (contoh: akun-utama):${N}"
    echo -n "  > "
    name_rc=0
    read_input name || name_rc=$?
    if (( name_rc == 2 )); then return 0; fi
    [[ -z "$name" ]] && { echo -e "  ${R}Dibatalkan.${N}"; press_enter || return $?; return; }

    vault_save "$name" "$email"

    echo -e "  ${G}✓ Qoder profile '$name' disimpan!${N}"
    press_enter || return $?
}

# === DELETE QODER PROFILE ===
delete_qoder() {
    header
    echo -e "  ${B}🗑️  Hapus Profile Qoder${N}"
    echo ""

    local all=()
    while IFS= read -r bn; do
        [[ -z "$bn" ]] && continue
        local email; email=$(vault_get_email "$bn")
        all+=("$bn  |  $email")
    done <<< "$(vault_list_names)"

    if [[ ${#all[@]} -eq 0 ]]; then
        echo -e "  ${D}Tidak ada profile Qoder tersimpan.${N}"
        press_enter || return $?; return
    fi

    for i in "${!all[@]}"; do
        echo -e "  ${B}$(( i + 1 )).${N} ${all[$i]}"
    done
    echo ""
    echo -e "  ${Y}Hapus [1-${#all[@]}] atau Enter untuk batal:${N}"
    echo -n "  > "
    pick_rc=0
    read_input pick || pick_rc=$?
    if (( pick_rc == 2 )); then return 0; fi

    if [[ -z "$pick" ]]; then return; fi
    if ! [[ "$pick" =~ ^[0-9]+$ ]] || (( pick < 1 || pick > ${#all[@]} )); then
        echo -e "  ${R}Pilihan tidak valid.${N}"
        press_enter || return $?; return
    fi

    local idx=$(( pick - 1 ))
    local chosen="${all[$idx]}"
    local name="${chosen%% *}"

    echo ""
    echo -e "  ${R}Hapus: $name${N}"
    echo -e "  ${Y}Yakin? [y/N]${N}"
    read -r confirm
    if [[ "$confirm" == "y" || "$confirm" == "Y" ]]; then
        vault_delete "$name"
        echo -e "  ${G}✓ Profile Qoder '$name' dihapus.${N}"
    else
        echo -e "  ${D}Dibatalkan.${N}"
    fi
    press_enter || return $?
}

# === AUTO-LOGIN QODER ===
autologin_qoder() {
    header
    echo -e "  ${B}🔓 Auto-Login Qoder${N} ${D}(Google SSO → Vault)${N}"
    echo ""

    local AUTOLOGIN_SCRIPT=""
    if ! AUTOLOGIN_SCRIPT=$(find_autologin "$SCRIPT_DIR" 2>/dev/null); then
        echo -e "  ${R}qoder-autologin tidak ditemukan.${N}"
        echo -e "  ${D}Install: symlink ke ~/.local/bin/ atau jalankan dari repo directory${N}"
        press_enter || return $?
        return
    fi

    # Check dependencies
    if ! command -v python3 &>/dev/null; then
        echo -e "  ${R}python3 tidak ditemukan.${N}"
        press_enter || return $?
        return
    fi

    if ! python3 -c "import playwright" 2>/dev/null; then
        echo -e "  ${Y}Playwright belum terinstall.${N}"
        echo -e "  ${D}Install: qoder-autologin setup${N}"
        echo ""
        echo -e "  ${Y}Install sekarang? [y/N]${N}"
        read -r install_ans
        if [[ "${install_ans,,}" == "y" ]]; then
            run_autologin "$AUTOLOGIN_SCRIPT" setup
            press_enter || return $?
            return
        else
            press_enter || return $?
            return
        fi
    fi

    echo -e "  ${Y}Pilih mode:${N}"
    echo ""
    echo -e "  ${C}1.${N} Single account (email:password)"
    echo -e "  ${C}2.${N} Batch dari file"
    echo -e "  ${C}3.${N} Interactive (input manual)"
    echo ""
    echo -n "  Pilih > "
    mode_rc=0
    read_input mode || mode_rc=$?
    if (( mode_rc == 2 )); then return 0; fi

    clear

    case "$mode" in
        1)
            echo -e "  ${Y}Format: email:password${N}"
            echo -n "  > "
            account_rc=0
            read_input account || account_rc=$?
            if (( account_rc == 2 )); then return 0; fi
            if [[ -z "$account" || "$account" != *":"* ]]; then
                echo -e "  ${R}Format tidak valid.${N}"
                press_enter || return $?
                return
            fi
            local email="${account%%:*}"
            local default_profile
            default_profile=$(echo "$email" | cut -d'@' -f1 | tr '.' '-')
            echo -e "  ${Y}Profile name [${default_profile}]:${N}"
            read -r profile
            profile="${profile:-$default_profile}"
            echo ""
            run_autologin "$AUTOLOGIN_SCRIPT" login "$account" "$profile"
            press_enter || return $?
            ;;
        2)
            echo -e "  ${Y}Path ke accounts file:${N}"
            echo -n "  > "
            filepath_rc=0
            read_input filepath || filepath_rc=$?
            if (( filepath_rc == 2 )); then return 0; fi
            if [[ -z "$filepath" ]]; then
                echo -e "  ${R}Dibatalkan.${N}"
                press_enter || return $?
                return
            fi
            # Expand ~
            filepath="${filepath/#\~/$HOME}"
            if [[ ! -f "$filepath" ]]; then
                echo -e "  ${R}File tidak ditemukan: $filepath${N}"
                press_enter || return $?
                return
            fi
            echo ""
            run_autologin "$AUTOLOGIN_SCRIPT" batch "$filepath"
            press_enter || return $?
            ;;
        3)
            run_autologin "$AUTOLOGIN_SCRIPT" interactive
            press_enter || return $?
            ;;
        *)
            echo -e "  ${R}Pilihan tidak valid.${N}"
            press_enter || return $?
            ;;
    esac
}

# === MAIN MENU ===
main() {
    while true; do
        dashboard

        echo -e "  ${C}1.${N} 🔗  OpenAI"
        echo -e "  ${C}2.${N} 🔑  Qoder CLI"
        echo -e "  ${C}3.${N} ➕  Simpan Qoder CLI"
        echo -e "  ${C}4.${N} 🗑️  Hapus Profile Qoder"
        echo -e "  ${C}5.${N} 🔓  Auto-Login Qoder"
        echo -e "  ${C}0.${N} ❌  Keluar"
        echo ""
        echo -n "  Pilih > "
        rc=0
        read_input choice || rc=$?
        if (( rc == 2 )); then continue; fi

        case "$choice" in
            1) detail_openai ;;
            2) detail_qoder ;;
            3) save_qoder ;;
            4) delete_qoder ;;
            5) autologin_qoder ;;
            0|"") echo -e "${D}Bye!${N}"; exit 0 ;;
            *) ;;
        esac
    done
}

main "$@"
