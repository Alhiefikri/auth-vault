COCKPIT_CODEX_ACCOUNTS="$HOME/.antigravity_cockpit/codex_accounts"
COCKPIT_QODER_ACCOUNTS="$HOME/.antigravity_cockpit/qoder_accounts"

# === COLORS ===
R='\033[0;31m'; G='\033[0;32m'; Y='\033[1;33m'; C='\033[0;36m'
B='\033[1m'; D='\033[2m'; N='\033[0m'
BG_G='\033[42m'; BG_R='\033[41m'; BG_C='\033[46m'; BG_Y='\033[43m'

mkdir -p "$VAULT_OPENAI" "$VAULT_QODER"

# === JWT HELPERS ===
jwt_decode() {
    echo "$1" | cut -d'.' -f2 | tr '_-' '/+' | base64 -d 2>/dev/null || true
}

jwt_email() {
    local p; p=$(jwt_decode "$1")
    echo "$p" | jq -r '."https://api.openai.com/profile".email // "?"' 2>/dev/null
}

jwt_plan() {
    local p; p=$(jwt_decode "$1")
    echo "$p" | jq -r '."https://api.openai.com/auth".chatgpt_plan_type // "?"' 2>/dev/null
}

jwt_exp_days() {
    local p; p=$(jwt_decode "$1")
    local exp; exp=$(echo "$p" | jq -r '.exp // 0' 2>/dev/null)
    local now; now=$(date +%s)
    if [[ "$exp" -gt "$now" ]]; then
        echo "$(( (exp - now) / 86400 ))d"
    else
        echo "expired"
    fi
}

