            # Determine email color based on vault current status
            local _dash_email_color="$G"
            local _dash_vn; _dash_vn=$(openai_vault_get_current) || true
            if [[ -n "$_dash_vn" ]]; then
                local _dash_ve; _dash_ve=$(openai_vault_get "$_dash_vn" "email") || true
                if [[ "$email" == "$_dash_ve" ]]; then
                    _dash_email_color="$C"
                fi
            fi
            [[ -n "$token" ]] && { plan=$(jwt_plan "$token"); exp=$(jwt_exp_days "$token"); }
            if [[ "$exp" == "expired" ]]; then
                exp_color="$R"
            elif [[ "$exp" =~ ^[0-9]+d$ ]]; then
                local days="${exp%d}"
                [[ $days -le 1 ]] && exp_color="$R"
                [[ $days -ge 2 && $days -le 3 ]] && exp_color="$Y"
                [[ $days -ge 4 ]] && exp_color="$G"
            fi
            local acct_id; acct_id=$(jq -r '.account_id // empty' "$COCKPIT_CODEX_ACCOUNTS/${cid}.json" 2>/dev/null)
            # Single live fetch: quota used% + reset timestamps from OpenAI (cached 60s)
            local live_q; live_q=$(fetch_codex_quota_cached "$token" "$acct_id")
            local bar="" h_reset_ts=""
            if [[ "$live_q" != "?|?|?|?" && "$live_q" != "?|?" ]]; then
                IFS='|' read -r hu wu hr wr <<< "$live_q"
                local h_rem="" w_rem=""
                if [[ "$hu" =~ ^[0-9]+$ ]]; then h_rem=$(( 100 - hu )); fi
                if [[ "$wu" =~ ^[0-9]+$ ]]; then w_rem=$(( 100 - wu )); fi
                [[ -n "$h_rem" ]] && bar="h:$(remaining_bar "$h_rem" 4)"
                h_reset_ts="$hr"
            else
                # Fallback to Cockpit cache
                local ud; ud=$(get_codex_usage "$email")
                local h="${ud%%|*}"
                [[ "$h" != "?" ]] && bar="h:$(remaining_bar $h 4)"
                local cr; cr=$(get_codex_reset "$email")
                h_reset_ts="${cr%%|*}"
            fi
            local reset_cd; reset_cd=$(reset_countdown "$h_reset_ts")
            local reset_color="$D"
            if [[ "$reset_cd" == "reset" ]]; then reset_color="$R"
            elif [[ "$reset_cd" =~ ^([0-9]+)h ]]; then
                (( ${BASH_REMATCH[1]} >= 2 )) && reset_color="$G" || reset_color="$Y"
            elif [[ "$reset_cd" =~ ^[0-9]+m$ ]]; then reset_color="$R"
            elif [[ "$reset_cd" =~ ^[0-9]+d ]]; then reset_color="$G"
            fi
            bar="${bar}  ${D}R:${N}${reset_color}${reset_cd}${N}"
            printf "  ${D}│${N} ${_dash_email_color}%-8s${N} ${D}│${N} ${_dash_email_color}%-28s${N} ${D}│${N} %-6s ${D}│${N} ${exp_color}%-7s${N} ${D}│${N} %b  ${D}│${N}\n" "OpenAI" "$email" "$plan" "$exp" "$bar"
        else
            printf "  ${D}│${N} %-8s ${D}│${N} ${D}%-28s${N} ${D}│${N} %-6s ${D}│${N} %-7s ${D}│${N} %-25s ${D}│${N}\n" "OpenAI" "(belum ada akun aktif)" "" "" ""
        fi
    else
        printf "  ${D}│${N} %-8s ${D}│${N} ${R}%-28s${N} ${D}│${N} %-6s ${D}│${N} %-7s ${D}│${N} %-25s ${D}│${N}\n" "OpenAI" "Cockpit tidak terdeteksi" "" "" ""
    fi

    # Qoder row
    if [[ -d "$COCKPIT_QODER_ACCOUNTS" ]]; then
        local qid; qid=$(get_current_qoder_id)
        if [[ -n "$qid" && -f "$COCKPIT_QODER_ACCOUNTS/${qid}.json" ]]; then
            local email; email=$(jq -r '.email // "?"' "$COCKPIT_QODER_ACCOUNTS/${qid}.json" 2>/dev/null)
            local plan; plan=$(jq -r '.plan_type // "?"' "$COCKPIT_QODER_ACCOUNTS/${qid}.json" 2>/dev/null)
            local ud; ud=$(get_qoder_usage "$email")
            local qp="${ud%%|*}" qbar=""
            if [[ "$qp" != "?" ]]; then
                local qr; qr=$(echo "$ud" | cut -d'|' -f4)
                local qt; qt=$(echo "$ud" | cut -d'|' -f3)
                local qpi=${qp%.*}
                qbar="cr:$(usage_bar $qpi 4) ${qr}/${qt}"
            fi
            printf "  ${D}│${N} ${C}%-8s${N} ${D}│${N} %-28s ${D}│${N} %-6s ${D}│${N} %-7s ${D}│${N} %b  ${D}│${N}\n" "Qoder" "$email" "$plan" "-" "$qbar"
        else
            printf "  ${D}│${N} %-8s ${D}│${N} ${D}%-28s${N} ${D}│${N} %-6s ${D}│${N} %-7s ${D}│${N} %-25s ${D}│${N}\n" "Qoder" "(belum ada akun aktif)" "" "" ""
        fi
    else
        printf "  ${D}│${N} %-8s ${D}│${N} ${D}%-28s${N} ${D}│${N} %-6s ${D}│${N} %-7s ${D}│${N} %-25s ${D}│${N}\n" "Qoder" "(belum ada akun)" "" "" ""
    fi

    echo -e "  ${D}└──────────┴─${hl}─┴────────┴─────────┴───────────────────────────┘${N}"
    # Vault info
    local _vault_name; _vault_name=$(openai_vault_get_current) || true
    local _cp_vault; _cp_vault=$(openai_vault_get_cockpit_active) || true
    if [[ -n "$_vault_name" || -n "$_cp_vault" ]]; then
        echo ""
        [[ -n "$_vault_name" ]] && echo -e "  ${C}vault current:${N}  $_vault_name"
        [[ -n "$_cp_vault" ]] && echo -e "  ${G}cockpit  →  vault:${N}  $_cp_vault"
    fi
    echo ""
    echo -e "  ${D}github.com/Alhiefikri/auth-vault${N}"
    echo ""
}

# === DETAIL OPENAI (list accounts + switch) ===
detail_openai() {
    header
    echo -e "  ${B}🔗 OpenAI${N} ${D}(via Cockpit Tools)${N}"
    echo ""

    if [[ ! -d "$COCKPIT_CODEX_ACCOUNTS" ]]; then
        echo -e "  ${R}Cockpit Tools tidak ditemukan.${N}"
        press_enter || return $?; return
    fi

    local _ss=0
    [[ "${AUTH_VAULT_SCREENSHOT:-}" == "1" ]] && _ss=1

    local current_id; current_id=$(get_current_codex_id)
    local ids=() emails=() plans=() exps=() tokens=() acct_ids=()
    for f in "$COCKPIT_CODEX_ACCOUNTS"/codex_*.json; do
        [[ -f "$f" ]] || continue
        local fid; fid=$(basename "$f" .json)
        local email; email=$(jq -r '.email // "?"' "$f" 2>/dev/null)
        local token; token=$(jq -r '.tokens.access_token // empty' "$f" 2>/dev/null)
        local acct_id; acct_id=$(jq -r '.account_id // empty' "$f" 2>/dev/null)
        local plan="?" exp="?"
        [[ -n "$token" ]] && { plan=$(jwt_plan "$token"); exp=$(jwt_exp_days "$token"); }
        # Screenshot mode: skip expired accounts
        if (( _ss )) && [[ "$exp" == "expired" ]]; then continue; fi
        ids+=("$fid"); emails+=("$email"); plans+=("$plan"); exps+=("$exp")
        tokens+=("$token"); acct_ids+=("$acct_id")
    done

    if [[ ${#ids[@]} -eq 0 ]]; then
        echo -e "  ${Y}Belum ada akun Codex di Cockpit.${N}"
        press_enter || return $?; return
    fi

    # Live-fetch quota + reset from OpenAI in parallel (cached 60s; stale-fallback)
    (( _ss == 0 )) && echo -e "  ${D}⟳ Refreshing quota & rate limits from OpenAI (parallel)...${N}"
    local parallel_args=()
    for i in "${!ids[@]}"; do
        parallel_args+=("${tokens[$i]}" "${acct_ids[$i]}")
    done
    local parallel_outfile; parallel_outfile=$(mktemp)
    local _t0; _t0=$(date +%s%N)
    fetch_codex_quota_parallel "$parallel_outfile" "${parallel_args[@]}"
    local _t1; _t1=$(date +%s%N)
    local _elapsed_ms=$(( (_t1 - _t0) / 1000000 ))
    (( _ss == 0 )) && echo -e "  ${D}  ⏱ ${#ids[@]} akun: ${_elapsed_ms}ms${N}" >&2
    mapfile -t parallel_lines < "$parallel_outfile"
    rm -f "$parallel_outfile"

    local live_h_used=() live_w_used=() live_h_resets=() live_w_resets=()
    for i in "${!ids[@]}"; do
        local rd="${parallel_lines[$i]:-}"
        if [[ -z "$rd" || "$rd" == "?|?|?|?" || "$rd" == "?|?" ]]; then
            # Full fallback to Cockpit cache for both used% and reset
            local cu; cu=$(get_codex_usage "${emails[$i]}")
            local cr; cr=$(get_codex_reset "${emails[$i]}")
            live_h_used+=("${cu%%|*}")
            local _cu_w="${cu#*|}"; live_w_used+=("${_cu_w%%|*}")
            live_h_resets+=("${cr%%|*}")
            live_w_resets+=("${cr##*|}")
        else
            # Parse 4-tuple: h_used|w_used|h_reset|w_reset
            IFS='|' read -r hu wu hr wr <<< "$rd"
            live_h_used+=("$hu"); live_w_used+=("$wu")
            live_h_resets+=("$hr"); live_w_resets+=("$wr")
        fi
    done

    # Dynamic email column width: total = 86 + email_col (added Reset column)
    local term_width=${COLUMNS:-100}
    local max_email=20
    for email in "${emails[@]}"; do
        [[ ${#email} -gt $max_email ]] && max_email=${#email}
    done
    local email_col=$(( term_width - 86 ))
    [[ $email_col -lt 20 ]] && email_col=20
    [[ $email_col -gt $max_email ]] && email_col=$max_email

    local ec_hl; ec_hl=$(hline "$email_col")
    local reset_hl; reset_hl=$(hline 14)
    local bars_hl; bars_hl=$(hline 33)

    # Get vault current email for marker display
    local vault_current_email=""
    local vault_current_name; vault_current_name=$(openai_vault_get_current)
    if [[ -n "$vault_current_name" ]]; then
        vault_current_email=$(openai_vault_get "$vault_current_name" "email")
    fi

    # Table header
    echo ""
    echo -e "  ${D}┌─────┬─${ec_hl}─┬──────────┬─────────┬─${reset_hl}─┬─${bars_hl}${N}"
    printf "  ${D}│${N} ${C}%2s${N}  ${D}│${N} ${C}%-${email_col}s${N} ${D}│${N} ${C}%-8s${N} ${D}│${N} ${C}%-7s${N} ${D}│${N} ${C}%-14s${N} ${D}│${N} ${C}%s${N}\n" \
        "#" "Email" "Plan" "Expire" "Reset (h / w)" "Quota Remaining (h / w)"
    echo -e "  ${D}├─────┼─${ec_hl}─┼──────────┼─────────┼─${reset_hl}─┼─${bars_hl}${N}"

    for i in "${!ids[@]}"; do
        local marker="o" mcolor="$D" ncolor="$D" ecolor="$D"
        if (( _ss )); then
            marker="o"; mcolor="$G"; ncolor="$G"; ecolor="$G"
        elif [[ "${ids[$i]}" == "$current_id" ]]; then
            marker="*"; mcolor="$G"; ncolor="$G"; ecolor="$G"
        elif [[ -n "$vault_current_email" && "${emails[$i]}" == "$vault_current_email" ]]; then
            marker="✦"; mcolor="$C"; ncolor="$C"; ecolor="$C"
        elif ! is_account_active "${emails[$i]}"; then
            marker="x"; mcolor="$Y"; ncolor="$Y"; ecolor="$Y"
        fi

        # Compute remaining % from live OpenAI used_percent (100 - used); fallback to "?"
        local hu="${live_h_used[$i]}" wu="${live_w_used[$i]}"
        local h w bar=""
        if [[ "$hu" =~ ^[0-9]+$ ]]; then h=$(( 100 - hu )); else h="?"; fi
        if [[ "$wu" =~ ^[0-9]+$ ]]; then w=$(( 100 - wu )); else w="?"; fi
        if [[ "$h" != "?" ]]; then
            bar="h:$(remaining_bar $h 4)  w:$(remaining_bar $w 4)"
            if (( _ss )); then
                # Strip per-widget colors, wrap everything in green
                bar=$(printf '%s' "$bar" | sed 's/\x1b\[[0-9;]*m//g')
                bar="${G}${bar}${N}"
            fi
        else
            bar="${D}─────────────────────────────────${N}"
        fi

        local h_reset="${live_h_resets[$i]}" w_reset="${live_w_resets[$i]}"
        local h_countdown; h_countdown=$(reset_countdown "$h_reset")
        local w_countdown; w_countdown=$(reset_countdown "$w_reset")
        local reset_display="${h_countdown} / ${w_countdown}"
        local reset_color="$D"
        if (( _ss )); then
            reset_color="$G"
        elif [[ "$h_countdown" == "reset" ]]; then
            reset_color="$R"
        elif [[ "$h_countdown" =~ ^([0-9]+)h ]]; then
            local rh="${BASH_REMATCH[1]}"
            (( rh >= 2 )) && reset_color="$G"
            (( rh == 1 )) && reset_color="$Y"
            (( rh == 0 )) && reset_color="$R"
        elif [[ "$h_countdown" =~ ^([0-9]+)m$ ]]; then
            reset_color="$R"
        elif [[ "$h_countdown" =~ ^([0-9]+)d ]]; then
            reset_color="$G"
        fi

        # Truncate email
        local display_email="${emails[$i]}"
        [[ ${#display_email} -gt $email_col ]] && display_email="${display_email:0:$((email_col-3))}..."

        # Color-coded expiry
        local exp_display="${exps[$i]}" exp_color="$D"
        if (( _ss )); then
            exp_color="$G"
        elif [[ "$exp_display" == "expired" ]]; then
            exp_color="$R"
        elif [[ "$exp_display" =~ ^[0-9]+d$ ]]; then
            local days="${exp_display%d}"
            [[ $days -le 1 ]] && exp_color="$R"
            [[ $days -ge 2 && $days -le 3 ]] && exp_color="$Y"
            [[ $days -ge 4 ]] && exp_color="$G"
        fi

        printf "  ${D}│${N} ${mcolor}%s${N}${ncolor}%1s${N} ${D}│${N} ${ecolor}%-${email_col}s${N} ${D}│${N} %-8s ${D}│${N} ${exp_color}%-7s${N} ${D}│${N} ${reset_color}%-14s${N} ${D}│${N} %b\n" \
            "$marker" "$((i+1))" "$display_email" "${plans[$i]}" "$exp_display" "$reset_display" "$bar"
    done
    echo -e "  ${D}└─────┴─${ec_hl}─┴──────────┴─────────┴─${reset_hl}─┴─${bars_hl}${N}"

    # Legend
    if (( _ss == 0 )); then
        echo ""
        echo -e "  ${G}*${N} cockpit current   ${C}✦${N} vault current   ${D}o${N} registered   ${Y}x${N} not in accounts.json"
    fi

    # Footer
    echo ""
    echo -e "  ${B}${#ids[@]} akun terdaftar${N}  ${D}│${N}  ${D}github.com/Alhiefikri/auth-vault${N}"
    echo ""
    echo -e "  ${Y}Switch akun [1-${#ids[@]}] atau Enter untuk batal:${N}"
    echo -n "  > "
    local pick_rc=0
    read_input pick || pick_rc=$?
    if (( pick_rc == 2 )); then return 0; fi

    if [[ -z "$pick" ]]; then return; fi
    if ! [[ "$pick" =~ ^[0-9]+$ ]] || (( pick < 1 || pick > ${#ids[@]} )); then
        echo -e "  ${R}Pilihan tidak valid.${N}"
        press_enter || return $?; return
    fi

    local idx=$(( pick - 1 ))
    local chosen_id="${ids[$idx]}"
    local chosen_file="$COCKPIT_CODEX_ACCOUNTS/${chosen_id}.json"
    local access; access=$(jq -r '.tokens.access_token' "$chosen_file")
    local refresh; refresh=$(jq -r '.tokens.refresh_token' "$chosen_file")
    local email; email=$(jq -r '.email // "?"' "$chosen_file")
    local account_id; account_id=$(jq -r '.account_id // .tokens.account_id // ""' "$chosen_file")
    local expires; expires=$(jwt_exp_ms "$access")

    echo ""
    echo -e "  ${G}Akun:${N} $email ($(jwt_plan "$access"))"
    echo -e "  ${Y}Apply ke semua app (omp, pi, opencode, codex)...${N}"

    local done_targets=()

    if [[ -f "$OMP_DB" ]]; then
        python3 "$SCRIPT_DIR/lib/vault_backends.py" write-omp \
            --db "$OMP_DB" \
            --access "$access" \
            --refresh "$refresh" \
            --expires "$expires" \
            --account-id "$account_id" \
            --email "$email" \
            --replaced-by "auth-vault" \
            2>/dev/null && done_targets+=("omp")
    fi

    if [[ -d "$(dirname "$PI_AUTH")" ]]; then
        python3 "$SCRIPT_DIR/lib/vault_backends.py" write-pi \
            --path "$PI_AUTH" \
            --access "$access" \
            --refresh "$refresh" \
            --expires "$expires" \
            --account-id "$account_id" \
            2>/dev/null && done_targets+=("pi")
    fi

    if [[ -f "$OPENCODE_AUTH" ]]; then
        python3 "$SCRIPT_DIR/lib/vault_backends.py" write-opencode \
            --path "$OPENCODE_AUTH" \
            --access "$access" \
            --refresh "$refresh" \
            --expires "$expires" \
            --account-id "$account_id" \
            2>/dev/null && done_targets+=("opencode")
    fi

    if [[ -f "$CODEX_AUTH" ]]; then
        python3 "$SCRIPT_DIR/lib/vault_backends.py" write-codex \
            --path "$CODEX_AUTH" \
            --access "$access" \
            --refresh "$refresh" \
            --expires "$expires" \
            --account-id "$account_id" \
            2>/dev/null && done_targets+=("codex")
    fi

    if [[ -f "$COCKPIT_CURRENT" ]]; then
        python3 "$SCRIPT_DIR/lib/vault_backends.py" update-cockpit-current \
            --path "$COCKPIT_CURRENT" \
            --provider "codex" \
            --account-id "$chosen_id" \
            2>/dev/null
    fi

    echo ""
    if [[ ${#done_targets[@]} -gt 0 ]]; then
        local joined; joined=$(IFS=' + '; echo "${done_targets[*]}")
        echo -e "  ${G}✓ Applied ke: $joined${N}"
        echo -e "  ${G}✓ Cockpit current updated${N}"
        echo -e "  ${D}Restart app untuk pakai akun baru.${N}"
    else
        echo -e "  ${R}Gagal apply.${N}"
    fi
    press_enter || return $?
}

# === DETAIL QODER (list accounts + switch) ===
detail_qoder() {
    header
    echo -e "  ${B}🔑 Qoder CLI${N}"
    echo ""

    if [[ -d "$COCKPIT_QODER_ACCOUNTS" ]]; then
        local current_qoder_id; current_qoder_id=$(get_current_qoder_id)
        sep
        printf "  ${C}%-4s${N}  %-28s  %-8s  %s\n" "" "Email" "Plan" "Credits"
        sep
        local count=0
        for f in "$COCKPIT_QODER_ACCOUNTS"/qoder_uid_*.json; do
            [[ -f "$f" ]] || continue
            local fid; fid=$(basename "$f" .json)
            local email; email=$(jq -r '.email // "?"' "$f" 2>/dev/null)
            is_qoder_account_active "$email" || continue
            count=$(( count + 1 ))
            local plan; plan=$(jq -r '.plan_type // "?"' "$f" 2>/dev/null)
            local marker="○" color="$D"
            [[ "$fid" == "$current_qoder_id" ]] && { marker="●"; color="$G"; }
            local ud; ud=$(get_qoder_usage "$email")
            local qp="${ud%%|*}" qbar=""
            if [[ "$qp" != "?" ]]; then
                local qr; qr=$(echo "$ud" | cut -d'|' -f4)
                local qt; qt=$(echo "$ud" | cut -d'|' -f3)
                local qpi=${qp%.*}
                qbar="cr:$(usage_bar $qpi 8) ${qr}/${qt}"
            fi
            printf "  ${color}%-4s${N}  %-28s  %-8s  %b\n" "$marker" "$email" "$plan" "$qbar"
        done
        [[ $count -eq 0 ]] && echo -e "  ${D}(belum ada akun Qoder di Cockpit)${N}"
        sep
        echo ""
    fi

    # Vault profiles
    local profiles=()
    local current_vault; current_vault=$(vault_get_current)
    while IFS= read -r pname; do
        [[ -z "$pname" ]] && continue
        profiles+=("$pname")
    done <<< "$(vault_list_names)"

    if [[ ${#profiles[@]} -gt 0 ]]; then
        echo -e "  ${B}Profile Vault:${N}"
        sep
        for i in "${!profiles[@]}"; do
            local pf="${profiles[$i]}"
            local email; email=$(vault_get_email "$pf")
            local marker="  "
            [[ "$pf" == "$current_vault" ]] && marker="→ "
            echo -e "  ${B}$(( i + 1 )).${N} ${marker}${pf}  ${D}|  $email${N}"
        done
        sep
        echo ""
        echo -e "  ${Y}Switch profile [1-${#profiles[@]}], [s] Simpan baru, [a] Add account (OAuth), atau Enter untuk batal:${N}"
    else
        echo -e "  ${D}Belum ada profile Qoder di vault.${N}"
        echo ""
        echo -e "  ${Y}[s] Simpan profile baru, [a] Add account (OAuth), atau Enter untuk batal:${N}"
    fi

    echo -n "  > "
    pick_rc=0
    read_input pick || pick_rc=$?
    if (( pick_rc == 2 )); then return 0; fi

    if [[ -z "$pick" ]]; then return; fi

    if [[ "$pick" == "s" ]]; then
        save_qoder
        return
    fi

    if [[ "$pick" == "a" ]]; then
        add_account_qoder
        return
    fi

    if [[ ${#profiles[@]} -eq 0 ]]; then
        echo -e "  ${R}Pilihan tidak valid.${N}"
        press_enter || return $?; return
    fi

    if ! [[ "$pick" =~ ^[0-9]+$ ]] || (( pick < 1 || pick > ${#profiles[@]} )); then
        echo -e "  ${R}Pilihan tidak valid.${N}"
        press_enter || return $?; return
    fi

    local idx=$(( pick - 1 ))
    local profile_name="${profiles[$idx]}"

    vault_use "$profile_name"

    echo ""
    echo -e "  ${G}✓ Qoder CLI diganti ke '$profile_name'!${N}"
    echo -e "  ${D}Restart qodercli untuk pakai akun baru.${N}"
    press_enter || return $?
}

# === SAVE QODER ===
save_qoder() {
    header
    echo -e "  ${B}➕ Simpan Akun Qoder CLI${N}"
    echo ""

    if [[ ! -f "$QODER_AUTH" ]]; then
        echo -e "  ${R}File auth Qoder CLI belum ada: $QODER_AUTH${N}"
        echo -e "  ${D}Login dulu: qodercli login${N}"
        press_enter || return $?; return
    fi

    local email="(unknown)"
    if [[ -f "$COCKPIT_CURRENT" ]]; then
        local qid; qid=$(jq -r '.current_accounts.qoder // empty' "$COCKPIT_CURRENT" 2>/dev/null || true)
        if [[ -n "$qid" ]]; then email=$(jq -r '.email // "?"' "$COCKPIT_QODER_ACCOUNTS/${qid}.json" 2>/dev/null || echo "?"); fi
    fi

    echo -e "  ${G}Auth file:${N} $QODER_AUTH"
    echo -e "  ${G}Cockpit:${N}   $email"
    echo ""

    local name
    echo -e "  ${Y}Nama profile (contoh: akun-utama):${N}"
    echo -n "  > "
    name_rc=0
    read_input name || name_rc=$?
    if (( name_rc == 2 )); then return 0; fi
    [[ -z "$name" ]] && { echo -e "  ${R}Dibatalkan.${N}"; press_enter || return $?; return; }

    vault_save "$name" "$email"

    echo -e "  ${G}✓ Qoder profile '$name' disimpan!${N}"
    press_enter || return $?
}

# === DELETE QODER PROFILE ===
delete_qoder() {
    header
    echo -e "  ${B}🗑️  Hapus Profile Qoder${N}"
    echo ""

    local all=()
    while IFS= read -r bn; do
        [[ -z "$bn" ]] && continue
        local email; email=$(vault_get_email "$bn")
        all+=("$bn  |  $email")
    done <<< "$(vault_list_names)"

    if [[ ${#all[@]} -eq 0 ]]; then
        echo -e "  ${D}Tidak ada profile Qoder tersimpan.${N}"
        press_enter || return $?; return
    fi

    for i in "${!all[@]}"; do
        echo -e "  ${B}$(( i + 1 )).${N} ${all[$i]}"
    done
    echo ""
    echo -e "  ${Y}Hapus [1-${#all[@]}] atau Enter untuk batal:${N}"
    echo -n "  > "
    pick_rc=0
    read_input pick || pick_rc=$?
    if (( pick_rc == 2 )); then return 0; fi

    if [[ -z "$pick" ]]; then return; fi
    if ! [[ "$pick" =~ ^[0-9]+$ ]] || (( pick < 1 || pick > ${#all[@]} )); then
        echo -e "  ${R}Pilihan tidak valid.${N}"
        press_enter || return $?; return
    fi

    local idx=$(( pick - 1 ))
    local chosen="${all[$idx]}"
    local name="${chosen%% *}"

    echo ""
    echo -e "  ${R}Hapus: $name${N}"
    echo -e "  ${Y}Yakin? [y/N]${N}"
    read -r confirm
    if [[ "$confirm" == "y" || "$confirm" == "Y" ]]; then
        vault_delete "$name"
        echo -e "  ${G}✓ Profile Qoder '$name' dihapus.${N}"
    else
        echo -e "  ${D}Dibatalkan.${N}"
    fi
    press_enter || return $?
}

# === ADD ACCOUNT QODER (OAuth) ===
add_account_qoder() {
    header
    echo -e "  ${B}➕ Add Account Qoder${N} ${D}(OAuth login → Vault)${N}"
    echo ""

    if ! command -v qodercli &>/dev/null; then
        echo -e "  ${R}qodercli tidak ditemukan di PATH.${N}"
        echo -e "  ${D}Install Qoder CLI terlebih dahulu.${N}"
        press_enter || return $?; return
    fi

    echo -e "  ${Y}Menjalankan qodercli login...${N}"
    echo -e "  ${D}Browser akan terbuka. Selesaikan login di browser.${N}"
    echo ""

    qoder_oauth_login
    if [[ "$QODER_OAUTH_RC" -ne 0 ]]; then
        echo ""
        echo -e "  ${R}Login gagal atau timeout.${N}"
        press_enter || return $?; return
    fi

    if [[ ! -f "$QODER_AUTH" ]]; then
        echo ""
        echo -e "  ${R}Auth file tidak terupdate.${N}"
        press_enter || return $?; return
    fi

    if [[ -n "${QODER_OAUTH_URL:-}" ]]; then
        echo -e "  ${D}URL: ${QODER_OAUTH_URL}${N}"
    fi

    echo ""
    echo -e "  ${G}✓ Login berhasil!${N}"
    echo ""

    local name
    echo -e "  ${Y}Nama profile (contoh: akun-utama):${N}"
    echo -n "  > "
    local name_rc=0
    read_input name || name_rc=$?
    if (( name_rc == 2 )); then return 0; fi
    if [[ -z "$name" ]]; then
        echo -e "  ${R}Dibatalkan.${N}"
        press_enter || return $?; return
    fi

    local email="(unknown)"
    if [[ -f "$COCKPIT_CURRENT" ]]; then
        local qid
        qid=$(jq -r '.current_accounts.qoder // empty' "$COCKPIT_CURRENT" 2>/dev/null || true)
        if [[ -n "$qid" && -f "$COCKPIT_QODER_ACCOUNTS/${qid}.json" ]]; then
            email=$(jq -r '.email // "?"' "$COCKPIT_QODER_ACCOUNTS/${qid}.json" 2>/dev/null || echo "?")
        fi
    fi

    vault_save "$name" "$email"
    echo -e "  ${G}✓ Profile '$name' disimpan ke vault!${N}"
    press_enter || return $?
}

# === AUTO-LOGIN QODER ===
autologin_qoder() {
    header
    echo -e "  ${B}🔓 Auto-Login Qoder${N} ${D}(Google SSO → Vault)${N}"
    echo ""

    local AUTOLOGIN_SCRIPT=""
    if ! AUTOLOGIN_SCRIPT=$(find_autologin "$SCRIPT_DIR" 2>/dev/null); then
        echo -e "  ${R}qoder-autologin tidak ditemukan.${N}"
        echo -e "  ${D}Install: symlink ke ~/.local/bin/ atau jalankan dari repo directory${N}"
        press_enter || return $?
        return
    fi

    # Check dependencies
    if ! command -v python3 &>/dev/null; then
        echo -e "  ${R}python3 tidak ditemukan.${N}"
        press_enter || return $?
        return
    fi

    if ! python3 -c "import playwright" 2>/dev/null; then
        echo -e "  ${Y}Playwright belum terinstall.${N}"
        echo -e "  ${D}Install: qoder-autologin setup${N}"
        echo ""
        echo -e "  ${Y}Install sekarang? [y/N]${N}"
        read -r install_ans
        if [[ "${install_ans,,}" == "y" ]]; then
            run_autologin "$AUTOLOGIN_SCRIPT" setup
            press_enter || return $?
            return
        else
            press_enter || return $?
            return
        fi
    fi

    echo -e "  ${Y}Pilih mode:${N}"
    echo ""
    echo -e "  ${C}1.${N} Single account (email:password)"
    echo -e "  ${C}2.${N} Batch dari file"
    echo -e "  ${C}3.${N} Interactive (input manual)"
    echo ""
    echo -n "  Pilih > "
    mode_rc=0
    read_input mode || mode_rc=$?
    if (( mode_rc == 2 )); then return 0; fi

    clear

    case "$mode" in
        1)
            echo -e "  ${Y}Format: email:password${N}"
            echo -n "  > "
            account_rc=0
            read_input account || account_rc=$?
            if (( account_rc == 2 )); then return 0; fi
            if [[ -z "$account" || "$account" != *":"* ]]; then
                echo -e "  ${R}Format tidak valid.${N}"
                press_enter || return $?
                return
            fi
            local email="${account%%:*}"
            local default_profile
            default_profile=$(echo "$email" | cut -d'@' -f1 | tr '.' '-')
            echo -e "  ${Y}Profile name [${default_profile}]:${N}"
            read -r profile
            profile="${profile:-$default_profile}"
            echo ""
            run_autologin "$AUTOLOGIN_SCRIPT" login "$account" "$profile"
            press_enter || return $?
            ;;
        2)
            echo -e "  ${Y}Path ke accounts file:${N}"
            echo -n "  > "
            filepath_rc=0
            read_input filepath || filepath_rc=$?
            if (( filepath_rc == 2 )); then return 0; fi
            if [[ -z "$filepath" ]]; then
                echo -e "  ${R}Dibatalkan.${N}"
                press_enter || return $?
                return
            fi
            # Expand ~
            filepath="${filepath/#\~/$HOME}"
            if [[ ! -f "$filepath" ]]; then
                echo -e "  ${R}File tidak ditemukan: $filepath${N}"
                press_enter || return $?
                return
            fi
            echo ""
            run_autologin "$AUTOLOGIN_SCRIPT" batch "$filepath"
            press_enter || return $?
            ;;
        3)
            run_autologin "$AUTOLOGIN_SCRIPT" interactive
            press_enter || return $?
            ;;
        *)
            echo -e "  ${R}Pilihan tidak valid.${N}"
            press_enter || return $?
            ;;
    esac
}

