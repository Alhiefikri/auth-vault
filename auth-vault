# === JWT HELPERS ===
jwt_decode() { echo "$1" | cut -d'.' -f2 | tr '_-' '/+' | base64 -d 2>/dev/null || true; }
jwt_email() { local p; p=$(jwt_decode "$1"); echo "$p" | jq -r '."https://api.openai.com/profile".email // "?"' 2>/dev/null; }
jwt_plan() { local p; p=$(jwt_decode "$1"); echo "$p" | jq -r '."https://api.openai.com/auth".chatgpt_plan_type // "?"' 2>/dev/null; }
jwt_exp_days() {
    local p; p=$(jwt_decode "$1")
    local exp; exp=$(echo "$p" | jq -r '.exp // 0' 2>/dev/null)
    local now; now=$(date +%s)
    if [[ "$exp" -gt "$now" ]]; then echo "$(( (exp - now) / 86400 ))d"; else echo "expired"; fi
}

