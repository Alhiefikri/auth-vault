# === COCKPIT HELPERS ===
get_current_codex_id() { [[ -f "$COCKPIT_CURRENT" ]] || { echo ""; return; }; jq -r '.current_accounts.codex // empty' "$COCKPIT_CURRENT" 2>/dev/null || echo ""; }
get_current_qoder_id() { [[ -f "$COCKPIT_CURRENT" ]] || { echo ""; return; }; jq -r '.current_accounts.qoder // empty' "$COCKPIT_CURRENT" 2>/dev/null || echo ""; }
get_codex_usage() {
    local email="$1"; [[ "$email" == "?" ]] && { echo "?|?"; return; }
    for f in "$COCKPIT_CODEX_ACCOUNTS"/codex_*.json; do
        [[ -f "$f" ]] || continue
        local femail; femail=$(jq -r '.email // ""' "$f" 2>/dev/null)
        if [[ "$femail" == "$email" ]]; then
            echo "$(jq -r '.quota.hourly_percentage // "?"' "$f" 2>/dev/null)|$(jq -r '.quota.weekly_percentage // "?"' "$f" 2>/dev/null)"
            return
        fi
    done
    echo "?|?"
}
fetch_codex_quota() {
    local token="$1" account_id="${2:-}"
    [[ -z "$token" ]] && { echo "?|?|?|?"; return; }
    local -a curl_args=(-sS --max-time 5 -H "Authorization: Bearer $token")
    [[ -n "$account_id" ]] && curl_args+=(-H "chatgpt-account-id: $account_id")
    local response
    response=$(curl "${curl_args[@]}" "https://chatgpt.com/backend-api/wham/usage" 2>/dev/null) || { echo "?|?|?|?"; return; }
    # Single jq call: extract all 4 fields, pipe-joined (was 5 separate jq calls)
    local result
    result=$(echo "$response" | jq -r '[.rate_limit.primary_window.used_percent // "?", .rate_limit.secondary_window.used_percent // "?", .rate_limit.primary_window.reset_at // "?", .rate_limit.secondary_window.reset_at // "?"] | join("|")' 2>/dev/null)
    [[ -z "$result" || "$result" == "?|?|?|?" ]] && { echo "?|?|?|?"; return; }
    echo "$result"
}
fetch_codex_quota_cached() {
    local token="$1" account_id="${2:-}"
    local cache_dir="${AUTH_VAULT_CACHE_DIR:-$HOME/.cache/auth-vault}"
    local ttl="${AUTH_VAULT_QUOTA_TTL:-60}"
    local key; key=$(printf '%s' "${token}|${account_id}" | md5sum); key="${key%% *}"
    local cache_file="$cache_dir/quota_${key}.json"
    mkdir -p "$cache_dir" 2>/dev/null || true

    # Try cache first: must exist, be fresh, and contain valid 4-field data
    if [[ -f "$cache_file" ]]; then
        local mtime now age
        mtime=$(stat -c %Y "$cache_file" 2>/dev/null || echo 0)
        now=$(date +%s)
        age=$(( now - mtime ))
        if (( age < ttl )); then
            local cached
            read -r cached < "$cache_file" 2>/dev/null || true
            # Validate shape: 4 pipe-separated non-empty fields
            if [[ "$cached" =~ ^[^|]+\|[^|]+\|[^|]+\|[^|]+$ ]]; then
                echo "$cached"
                return
            fi
            # Corrupt → fall through to fetch
            rm -f "$cache_file" 2>/dev/null || true
        fi
    fi

    # Cache miss / stale: fetch from API
    local fresh; fresh=$(fetch_codex_quota "$token" "$account_id")
    if [[ "$fresh" != "?|?|?|?" ]]; then
        printf '%s' "$fresh" > "$cache_file" 2>/dev/null || true
        echo "$fresh"
        return
    fi

    # API failed: graceful degradation — return stale cache if available
    if [[ -f "$cache_file" ]]; then
        local cached
        read -r cached < "$cache_file" 2>/dev/null || true
        if [[ "$cached" =~ ^[^|]+\|[^|]+\|[^|]+\|[^|]+$ ]]; then
            echo "$cached"
            return
        fi
    fi

    echo "?|?|?|?"
}
fetch_codex_quota_parallel() {
    local outfile="$1"; shift
    : > "$outfile"
    [[ $# -eq 0 ]] && return 0
    (( $# % 2 == 0 )) || return 1
    local n=$(( $# / 2 ))
    local tmpdir; tmpdir=$(mktemp -d)
    local i=0
    while (( i < n )); do
        local tok="$1" acct="$2"; shift 2
        (
            local r; r=$(fetch_codex_quota_cached "$tok" "$acct")
            printf '%s\n' "$r" > "$tmpdir/$i"
        ) &
        (( ++i ))
    done
    wait
    for (( i = 0; i < n; i++ )); do
        if [[ -f "$tmpdir/$i" ]]; then
            read -r line < "$tmpdir/$i" || true
            echo "$line"
        else
            echo "?|?|?|?"
        fi
    done > "$outfile"
    rm -rf "$tmpdir"
    return 0
}
fetch_codex_reset() {
    local token="$1" account_id="${2:-}"
    local full; full=$(fetch_codex_quota "$token" "$account_id")
    if [[ "$full" == "?|?|?|?" ]]; then echo "?|?"; return; fi
    # Strip first two fields (h_used|w_used) → keep h_reset|w_reset
    local rest="${full#*|}"; rest="${rest#*|}"
    echo "$rest"
}
get_codex_reset() {
    local email="$1"; [[ "$email" == "?" ]] && { echo "?|?"; return; }
    for f in "$COCKPIT_CODEX_ACCOUNTS"/codex_*.json; do
        [[ -f "$f" ]] || continue
        local femail; femail=$(jq -r '.email // ""' "$f" 2>/dev/null)
        if [[ "$femail" == "$email" ]]; then
            local h_reset w_reset h_window w_window now
            h_reset=$(jq -r '.quota.hourly_reset_time // "?"' "$f" 2>/dev/null)
            w_reset=$(jq -r '.quota.weekly_reset_time // "?"' "$f" 2>/dev/null)
            h_window=$(jq -r '.quota.hourly_window_minutes // 300' "$f" 2>/dev/null)
            w_window=$(jq -r '.quota.weekly_window_minutes // 10080' "$f" 2>/dev/null)
            now=$(date +%s)
            if [[ "$h_reset" =~ ^[0-9]+$ ]]; then
                local h_win_sec=$(( h_window * 60 ))
                while (( h_reset <= now )); do h_reset=$(( h_reset + h_win_sec )); done
            fi
            if [[ "$w_reset" =~ ^[0-9]+$ ]]; then
                local w_win_sec=$(( w_window * 60 ))
                while (( w_reset <= now )); do w_reset=$(( w_reset + w_win_sec )); done
            fi
            echo "${h_reset:-?}|${w_reset:-?}"
            return
        fi
    done
    echo "?|?"
}
get_qoder_usage() {
    local email="$1"; [[ "$email" == "?" || "$email" == "(none)" ]] && { echo "?"; return; }
    for f in "$COCKPIT_QODER_ACCOUNTS"/qoder_uid_*.json; do
        [[ -f "$f" ]] || continue
        local femail; femail=$(jq -r '.email // ""' "$f" 2>/dev/null)
        if [[ "$femail" == "$email" ]]; then
            echo "$(jq -r '.credits_usage_percent // 0' "$f" 2>/dev/null)|$(jq -r '.credits_used // 0' "$f" 2>/dev/null)|$(jq -r '.credits_total // 0' "$f" 2>/dev/null)|$(jq -r '.credits_remaining // 0' "$f" 2>/dev/null)"
            return
        fi
    done
    echo "?|?|?|?"
}
is_account_active() {
    local email="$1"
    [[ -f "$COCKPIT_ACCOUNTS" ]] || return 0
    local result
    result=$(jq -r --arg e "$email" '.accounts[] | select(.email == $e) | .email' "$COCKPIT_ACCOUNTS" 2>/dev/null)
    [[ -n "$result" ]]
}
is_qoder_account_active() {
    local email="$1"
    local qjson="$HOME/.antigravity_cockpit/qoder_accounts.json"
    [[ -f "$qjson" ]] || return 0
    local result
    result=$(jq -r --arg e "$email" '.accounts[] | select(.email == $e) | .email' "$qjson" 2>/dev/null)
    [[ -n "$result" ]]
}

