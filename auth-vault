_openai_exchange_and_save() {
    local code="$1"
    local port="$2"

    echo -e "  ${Y}Menukar code dengan token...${N}"
    local token_response
    token_response=$(openai_oauth_exchange_code "$code" "$port") || {
        echo -e "  ${R}Gagal menukar code.${N}"
        press_enter || return $?; return
    }

    local access_token refresh_token
    access_token=$(echo "$token_response" | jq -r '.access_token // empty' 2>/dev/null)
    refresh_token=$(echo "$token_response" | jq -r '.refresh_token // empty' 2>/dev/null)

    if [[ -z "$access_token" ]]; then
        echo -e "  ${R}Token tidak ditemukan di response.${N}"
        press_enter || return $?; return
    fi

    local email account_id
    email=$(echo "$access_token" | jq -Rr 'split(".") | .[1] | @base64d | fromjson | ."https://api.openai.com/profile".email // "?"' 2>/dev/null || echo "?")
    account_id=$(echo "$access_token" | jq -Rr 'split(".") | .[1] | @base64d | fromjson | ."https://api.openai.com/auth".chatgpt_account_id // ""' 2>/dev/null || echo "")

    local default_name
    default_name=$(echo "$email" | cut -d'@' -f1 | tr '.' '-')

    echo ""
    echo -e "  ${G}✓ Token didapatkan!${N}"
    echo -e "  ${D}Email: $email${N}"
    echo ""
    echo -e "  ${Y}Nama akun [${default_name}]:${N}"
    echo -n "  > "
    local name
    local name_rc=0
    read_input name || name_rc=$?
    if (( name_rc == 2 )); then return 0; fi
    name="${name:-$default_name}"

    openai_vault_save "$name" "$email" "$access_token" "$refresh_token" "$account_id"
    echo -e "  ${G}✓ Akun '$name' disimpan ke vault!${N}"
    press_enter || return $?
}

_openai_finish_add() {
    local method="$1"
    echo -e "  ${Y}Menukar code dengan token...${N}"

    local code="${OPENAI_OAUTH_CODE:-}"
    OPENAI_OAUTH_CODE=""

    if [[ -z "$code" ]]; then
        echo -e "  ${Y}Masukkan code dari redirect URL:${N}"
        echo -n "  > "
        read_input code || return 0
    fi

    if [[ -z "$code" ]]; then
        echo -e "  ${R}Code kosong.${N}"
        press_enter || return $?; return
    fi

    _openai_exchange_and_save "$code" "${OPENAI_OAUTH_PORT:-1455}"
}

# === OPENAI: DELETE ACCOUNT ===
delete_account_openai() {
    header
    echo -e "  ${B}🗑️  Hapus Akun OpenAI${N}"
    echo ""

    local count
    count=$(openai_vault_count)
    if [[ "$count" -eq 0 ]]; then
        echo -e "  ${Y}Belum ada akun OpenAI di vault.${N}"
        press_enter || return $?; return
    fi

    local names=()
    while IFS= read -r line; do
        [[ -n "$line" ]] && names+=("$line")
    done < <(openai_vault_list)

    for i in "${!names[@]}"; do
        local email
        email=$(openai_vault_get "${names[$i]}" "email")
        echo -e "  ${B}$(( i + 1 )).${N} ${names[$i]} ${D}($email)${N}"
    done
    echo ""
    echo -e "  ${Y}Hapus [1-${#names[@]}] atau Enter untuk batal:${N}"
    echo -n "  > "
    local pick
    local pick_rc=0
    read_input pick || pick_rc=$?
    if (( pick_rc == 2 )); then return 0; fi

    if [[ -z "$pick" ]]; then return; fi
    if ! [[ "$pick" =~ ^[0-9]+$ ]] || (( pick < 1 || pick > ${#names[@]} )); then
        echo -e "  ${R}Pilihan tidak valid.${N}"
        press_enter || return $?; return
    fi

    local idx=$(( pick - 1 ))
    local chosen="${names[$idx]}"

    echo ""
    echo -e "  ${R}Hapus: $chosen${N}"
    echo -e "  ${Y}Yakin? [y/N]${N}"
    read -r confirm
    if [[ "$confirm" == "y" || "$confirm" == "Y" ]]; then
        openai_vault_delete "$chosen"
        echo -e "  ${G}✓ Akun OpenAI '$chosen' dihapus dari vault.${N}"
    else
        echo -e "  ${D}Dibatalkan.${N}"
    fi
    press_enter || return $?
}

