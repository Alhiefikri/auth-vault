#!/bin/bash
# qoder-auth-swap - Manage Qoder CLI auth profiles
# Usage: qoder-auth-swap [save|use|list|status] [name]

set -euo pipefail

QODER_AUTH="$HOME/.qoder/.auth/user"
QODER_PROFILES_DIR="$HOME/.qoder/.auth/profiles"
COCKPIT_QODER_ACCOUNTS="$HOME/.antigravity_cockpit/qoder_accounts"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
DIM='\033[2m'
NC='\033[0m'

info()  { echo -e "${GREEN}[OK]${NC} $*"; }
warn()  { echo -e "${YELLOW}[!]${NC} $*"; }
err()   { echo -e "${RED}[ERR]${NC} $*" >&2; }

ensure_profiles_dir() {
    mkdir -p "$QODER_PROFILES_DIR"
}

get_current_email() {
    if [[ ! -f "$QODER_AUTH" ]]; then
        echo "?"
        return
    fi
    local link="$QODER_PROFILES_DIR/.current"
    if [[ -f "$link" ]]; then
        cat "$link"
    else
        echo "(unknown)"
    fi
}

cmd_save() {
    local name="${1:-}"
    if [[ -z "$name" ]]; then
        err "Usage: qoder-auth-swap save <name>"
        echo "  Simpan auth Qoder CLI saat ini sebagai profile."
        echo "  Contoh: qoder-auth-swap save akun-utama"
        exit 1
    fi

    if [[ ! -f "$QODER_AUTH" ]]; then
        err "File auth Qoder CLI belum ada: $QODER_AUTH"
        err "Login dulu: qodercli login"
        exit 1
    fi

    ensure_profiles_dir
    cp "$QODER_AUTH" "$QODER_PROFILES_DIR/$name"
    echo "$name" > "$QODER_PROFILES_DIR/.current"

    info "Profile '$name' berhasil disimpan!"
    echo "  File: $QODER_PROFILES_DIR/$name"
}

cmd_use() {
    local name="${1:-}"
    if [[ -z "$name" ]]; then
        err "Usage: qoder-auth-swap use <name>"
        echo "  Pakai profile yang sudah disimpan."
        echo "  Lihat daftar: qoder-auth-swap list"
        exit 1
    fi

    local profile="$QODER_PROFILES_DIR/$name"
    if [[ ! -f "$profile" ]]; then
        err "Profile '$name' tidak ditemukan."
        echo "  Lihat daftar: qoder-auth-swap list"
        exit 1
    fi

    # backup current
    if [[ -f "$QODER_AUTH" ]]; then
        cp "$QODER_AUTH" "$QODER_AUTH.bak"
    fi

    cp "$profile" "$QODER_AUTH"
    echo "$name" > "$QODER_PROFILES_DIR/.current"

    info "Auth Qoder CLI diganti ke profile '$name'!"
    echo "  Restart qodercli untuk pakai akun baru."
}

cmd_list() {
    ensure_profiles_dir

    echo -e "${CYAN}=== Qoder CLI Auth Profiles ===${NC}"
    echo ""

    local current
    current=$(cat "$QODER_PROFILES_DIR/.current" 2>/dev/null || echo "")

    local sep="──────────────────────────────────────────────"
    echo -e "  ${DIM}${sep}${NC}"
    printf "  ${CYAN}%-20s${NC}  %-10s  %s\n" "Profile" "Size" "Status"
    echo -e "  ${DIM}${sep}${NC}"

    local found=false
    for profile in "$QODER_PROFILES_DIR"/*; do
        [[ -f "$profile" ]] || continue
        local pname
        pname=$(basename "$profile")
        [[ "$pname" == ".current" ]] && continue
        found=true

        local size
        size=$(wc -c < "$profile")
        local status=""
        if [[ "$pname" == "$current" ]]; then
            status="${GREEN}aktif${NC}"
        fi
        printf "  %-20s  %-10s  %b\n" "$pname" "${size} bytes" "$status"
    done

    if [[ "$found" != "true" ]]; then
        echo -e "  ${DIM}(belum ada profile)${NC}"
        echo ""
        echo "  Tambah profile:"
        echo "    1. Login: ${CYAN}qodercli login${NC}"
        echo "    2. Simpan: ${CYAN}qoder-auth-swap save <nama>${NC}"
    fi

    echo -e "  ${DIM}${sep}${NC}"
    echo ""
}

cmd_status() {
    echo -e "${CYAN}=== Qoder CLI Auth Status ===${NC}"
    echo ""

    local sep="──────────────────────────────────────────────"
    echo -e "  ${DIM}${sep}${NC}"
    printf "  ${CYAN}%-15s${NC}  %s\n" "Item" "Detail"
    echo -e "  ${DIM}${sep}${NC}"

    # Current profile
    local current
    current=$(cat "$QODER_PROFILES_DIR/.current" 2>/dev/null || echo "(none)")
    printf "  %-15s  %s\n" "Profile aktif" "$current"

    # Auth file
    if [[ -f "$QODER_AUTH" ]]; then
        local size
        size=$(wc -c < "$QODER_AUTH")
        local modified
        modified=$(stat -c '%y' "$QODER_AUTH" 2>/dev/null | cut -d'.' -f1 || echo "?")
        printf "  %-15s  %s\n" "Auth file" "${size} bytes"
        printf "  %-15s  %s\n" "Modified" "$modified"
    else
        printf "  %-15s  %s\n" "Auth file" "(belum ada)"
    fi

    # Cockpit Tools current Qoder account
    if [[ -f "$HOME/.antigravity_cockpit/provider_current_accounts.json" ]]; then
        local cockpit_id
        cockpit_id=$(jq -r '.current_accounts.qoder // empty' "$HOME/.antigravity_cockpit/provider_current_accounts.json" 2>/dev/null)
        if [[ -n "$cockpit_id" ]]; then
            local cockpit_email
            cockpit_email=$(jq -r '.email // "?"' "$COCKPIT_QODER_ACCOUNTS/${cockpit_id}.json" 2>/dev/null || echo "?")
            local cockpit_plan
            cockpit_plan=$(jq -r '.plan_type // "?"' "$COCKPIT_QODER_ACCOUNTS/${cockpit_id}.json" 2>/dev/null || echo "?")
            printf "  %-15s  %s\n" "Cockpit akun" "$cockpit_email ($cockpit_plan)"
        else
            printf "  %-15s  %s\n" "Cockpit akun" "(tidak ada akun Qoder aktif)"
        fi
    fi

    # Total saved profiles
    ensure_profiles_dir
    local count
    count=$(find "$QODER_PROFILES_DIR" -maxdepth 1 -type f ! -name '.current' | wc -l)
    printf "  %-15s  %s\n" "Saved profiles" "$count"

    echo -e "  ${DIM}${sep}${NC}"
    echo ""
}

cmd_batch_save() {
    echo -e "${CYAN}=== Batch Save dari Cockpit Tools ===${NC}"
    echo ""
    echo "Script ini akan menyimpan auth file Qoder CLI saat ini,"
    echo "lalu kamu perlu login manual ke setiap akun yang mau disimpan."
    echo ""
    warn "Fitur ini butuh login manual per akun (qodercli login)"
    echo ""
    echo "Alternatif: simpan satu per satu pakai:"
    echo "  1. qodercli login (login ke akun X)"
    echo "  2. qoder-auth-swap save nama-akun-x"
    echo ""
    echo "Lalu swap kapan saja:"
    echo "  qoder-auth-swap use nama-akun-x"
}

main() {
    local cmd="${1:-status}"
    shift 2>/dev/null || true

    case "$cmd" in
        save)     cmd_save "$@" ;;
        use)      cmd_use "$@" ;;
        list)     cmd_list ;;
        status|-s|--status) cmd_status ;;
        batch)    cmd_batch_save ;;
        -h|--help|help)
            echo "Usage: qoder-auth-swap <command> [args]"
            echo ""
            echo "Commands:"
            echo "  save <name>     Simpan auth CLI saat ini sebagai profile"
            echo "  use <name>      Ganti auth CLI ke profile yang disimpan"
            echo "  list            Tampilkan semua profile yang disimpan"
            echo "  status          Tampilkan status auth saat ini"
            echo ""
            echo "Workflow:"
            echo "  1. qodercli login           # login ke akun A"
            echo "  2. qoder-auth-swap save akun-a"
            echo "  3. qodercli login           # login ke akun B"
            echo "  4. qoder-auth-swap save akun-b"
            echo "  5. qoder-auth-swap use akun-a  # switch kapan saja"
            ;;
        *)
            err "Command tidak dikenal: $cmd"
            echo "  Run: qoder-auth-swap --help"
            exit 1
            ;;
    esac
}

main "$@"
