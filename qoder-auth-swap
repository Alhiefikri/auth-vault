#!/bin/bash
# qoder-auth-swap - Manage Qoder CLI auth profiles
# Usage: qoder-auth-swap [save|use|list|delete|status] [name]

set -euo pipefail

VAULT_DIR="$HOME/.auth-vault/qoder"
QODER_AUTH="$HOME/.qoder/.auth/user"
OLD_PROFILES_DIR="$HOME/.qoder/.auth/profiles"
COCKPIT_QODER_ACCOUNTS="$HOME/.antigravity_cockpit/qoder_accounts"

SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
source "$SCRIPT_DIR/lib/vault-profiles.sh"
source "$SCRIPT_DIR/lib/find-autologin.sh"
source "$SCRIPT_DIR/lib/qoder-oauth.sh"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
DIM='\033[2m'
NC='\033[0m'

info()  { echo -e "${GREEN}[OK]${NC} $*"; }
warn()  { echo -e "${YELLOW}[!]${NC} $*"; }
err()   { echo -e "${RED}[ERR]${NC} $*" >&2; }

cmd_save() {
    local name="${1:-}"
    if [[ -z "$name" ]]; then
        err "Usage: qoder-auth-swap save <name>"
        echo "  Simpan auth Qoder CLI saat ini sebagai profile."
        echo "  Contoh: qoder-auth-swap save akun-utama"
        exit 1
    fi

    if [[ ! -f "$QODER_AUTH" ]]; then
        err "File auth Qoder CLI belum ada: $QODER_AUTH"
        err "Login dulu: qodercli login"
        exit 1
    fi

    vault_save "$name" "$(_detect_email)"
    info "Profile '$name' berhasil disimpan!"
    echo "  File: $VAULT_DIR/$name"
}

cmd_use() {
    local name="${1:-}"
    if [[ -z "$name" ]]; then
        err "Usage: qoder-auth-swap use <name>"
        echo "  Pakai profile yang sudah disimpan."
        echo "  Lihat daftar: qoder-auth-swap list"
        exit 1
    fi

    if ! vault_use "$name"; then
        err "Profile '$name' tidak ditemukan."
        echo "  Lihat daftar: qoder-auth-swap list"
        exit 1
    fi

    info "Auth Qoder CLI diganti ke profile '$name'!"
    echo "  Restart qodercli untuk pakai akun baru."
}

cmd_list() {
    echo -e "${CYAN}=== Qoder CLI Auth Profiles ===${NC}"
    echo ""

    local current; current=$(vault_get_current)
    local sep="──────────────────────────────────────────────"
    echo -e "  ${DIM}${sep}${NC}"
    printf "  ${CYAN}%-20s${NC}  %-24s  %s\n" "Profile" "Email" "Status"
    echo -e "  ${DIM}${sep}${NC}"

    local found=false
    local names; names=$(vault_list_names)
    while IFS= read -r pname; do
        [[ -z "$pname" ]] && continue
        found=true
        local email; email=$(vault_get_email "$pname")
        local status=""
        [[ "$pname" == "$current" ]] && status="${GREEN}aktif${NC}"
        printf "  %-20s  %-24s  %b\n" "$pname" "$email" "$status"
    done <<< "$names"

    if [[ "$found" != "true" ]]; then
        echo -e "  ${DIM}(belum ada profile)${NC}"
        echo ""
        echo "  Tambah profile:"
        echo "    1. OAuth: ${CYAN}qoder-auth-swap add-account <nama>${NC}"
        echo "    2. Atau:  ${CYAN}qodercli login${NC} lalu ${CYAN}qoder-auth-swap save <nama>${NC}"
    fi

    echo -e "  ${DIM}${sep}${NC}"
    echo ""
}

cmd_status() {
    echo -e "${CYAN}=== Qoder CLI Auth Status ===${NC}"
    echo ""

    local sep="──────────────────────────────────────────────"
    echo -e "  ${DIM}${sep}${NC}"
    printf "  ${CYAN}%-15s${NC}  %s\n" "Item" "Detail"
    echo -e "  ${DIM}${sep}${NC}"

    local current; current=$(vault_get_current)
    printf "  %-15s  %s\n" "Profile aktif" "${current:-(none)}"

    if [[ -f "$QODER_AUTH" ]]; then
        local size; size=$(wc -c < "$QODER_AUTH")
        local modified; modified=$(stat -c '%y' "$QODER_AUTH" 2>/dev/null | cut -d'.' -f1 || echo "?")
        printf "  %-15s  %s\n" "Auth file" "${size} bytes"
        printf "  %-15s  %s\n" "Modified" "$modified"
    else
        printf "  %-15s  %s\n" "Auth file" "(belum ada)"
    fi

    if [[ -f "$HOME/.antigravity_cockpit/provider_current_accounts.json" ]]; then
        local cockpit_id
        cockpit_id=$(jq -r '.current_accounts.qoder // empty' "$HOME/.antigravity_cockpit/provider_current_accounts.json" 2>/dev/null)
        if [[ -n "$cockpit_id" ]]; then
            local cockpit_email; cockpit_email=$(jq -r '.email // "?"' "$COCKPIT_QODER_ACCOUNTS/${cockpit_id}.json" 2>/dev/null || echo "?")
            local cockpit_plan; cockpit_plan=$(jq -r '.plan_type // "?"' "$COCKPIT_QODER_ACCOUNTS/${cockpit_id}.json" 2>/dev/null || echo "?")
            printf "  %-15s  %s\n" "Cockpit akun" "$cockpit_email ($cockpit_plan)"
        else
            printf "  %-15s  %s\n" "Cockpit akun" "(tidak ada akun Qoder aktif)"
        fi
    fi

    printf "  %-15s  %s\n" "Saved profiles" "$(vault_count)"

    echo -e "  ${DIM}${sep}${NC}"
    echo ""
}

cmd_delete() {
    local name="${1:-}"
    if [[ -z "$name" ]]; then
        err "Usage: qoder-auth-swap delete <name>"
        echo "  Hapus profile dari vault."
        exit 1
    fi

    if ! vault_delete "$name"; then
        err "Profile '$name' tidak ditemukan."
        exit 1
    fi

    info "Profile '$name' dihapus."
}

cmd_batch_save() {
    echo -e "${CYAN}=== Batch Save dari Cockpit Tools ===${NC}"
    echo ""
    echo "Script ini akan menyimpan auth file Qoder CLI saat ini,"
    echo "lalu kamu perlu login manual ke setiap akun yang mau disimpan."
    echo ""
    warn "Fitur ini butuh login manual per akun (qodercli login)"
    echo ""
    echo "Alternatif: simpan satu per satu pakai:"
    echo "  1. qodercli login (login ke akun X)"
    echo "  2. qoder-auth-swap save nama-akun-x"
    echo ""
    echo "Lalu swap kapan saja:"
    echo "  qoder-auth-swap use nama-akun-x"
}

cmd_login() {
    local account="${1:-}"
    local profile="${2:-}"

    if [[ -z "$account" ]]; then
        err "Usage: qoder-auth-swap login <email:password> [profile_name]"
        echo "  Auto-login via Google SSO + simpan ke vault."
        echo "  Contoh: qoder-auth-swap login user@gmail.com:pass123 akun-utama"
        exit 1
    fi

    local autologin
    if ! autologin=$(find_autologin "$SCRIPT_DIR" 2>/dev/null); then
        err "qoder-autologin tidak ditemukan."
        echo "  Install: symlink ke ~/.local/bin/ atau jalankan dari repo directory"
        exit 1
    fi

    local args=("login" "$account")
    [[ -n "$profile" ]] && args+=("$profile")
    run_autologin "$autologin" "${args[@]}"
}

cmd_batch_login() {
    local file="${1:-}"

    if [[ -z "$file" ]]; then
        err "Usage: qoder-auth-swap batch-login <accounts_file>"
        echo "  Batch auto-login dari file (format: email:password per baris)."
        echo "  Contoh: qoder-auth-swap batch-login accounts.txt"
        exit 1
    fi

    local autologin
    if ! autologin=$(find_autologin "$SCRIPT_DIR" 2>/dev/null); then
        err "qoder-autologin tidak ditemukan."
        exit 1
    fi

    run_autologin "$autologin" batch "$file"
}

cmd_add_account() {
    local profile="${1:-}"

    if ! command -v qodercli &>/dev/null; then
        err "qodercli tidak ditemukan di PATH."
        echo "  Install Qoder CLI terlebih dahulu."
        exit 1
    fi

    echo -e "${CYAN}=== Add Account Qoder (OAuth) ===${NC}"
    echo ""
    echo "Menjalankan qodercli login..."
    echo "Browser akan terbuka. Selesaikan login di browser."
    echo ""

    qoder_oauth_login
    if [[ "$QODER_OAUTH_RC" -ne 0 ]]; then
        err "Login gagal atau timeout."
        exit 1
    fi

    if [[ ! -f "$QODER_AUTH" ]]; then
        err "Auth file tidak terupdate."
        exit 1
    fi

    if [[ -n "${QODER_OAUTH_URL:-}" ]]; then
        echo -e "${DIM}URL: ${QODER_OAUTH_URL}${NC}"
    fi

    info "Login berhasil!"
    echo ""

    if [[ -z "$profile" ]]; then
        echo -n "Nama profile: "
        read -r profile
    fi

    if [[ -z "$profile" ]]; then
        err "Profile name kosong. Dibatalkan."
        exit 1
    fi

    vault_save "$profile" "$(_detect_email)"
    info "Profile '$profile' disimpan ke vault!"
    echo "  File: $VAULT_DIR/$profile"
}

main() {
    vault_migrate

    local cmd="${1:-status}"
    shift 2>/dev/null || true

    case "$cmd" in
        save)     cmd_save "$@" ;;
        use)      cmd_use "$@" ;;
        list)     cmd_list ;;
        delete)   cmd_delete "$@" ;;
        status|-s|--status) cmd_status ;;
        login)    cmd_login "$@" ;;
        batch-login) cmd_batch_login "$@" ;;
        add-account) cmd_add_account "$@" ;;
        batch)    cmd_batch_save ;;
        -h|--help|help)
            echo "Usage: qoder-auth-swap <command> [args]"
            echo ""
            echo "Commands:"
            echo "  save <name>                 Simpan auth CLI saat ini sebagai profile"
            echo "  use <name>                  Ganti auth CLI ke profile yang disimpan"
            echo "  list                        Tampilkan semua profile yang disimpan"
            echo "  delete <name>               Hapus profile dari vault"
            echo "  status                      Tampilkan status auth saat ini"
            echo "  login <email:pass> [name]   Auto-login via Google SSO + simpan ke vault"
            echo "  batch-login <file>          Batch auto-login dari file"
            echo "  add-account [name]          Login via OAuth (qodercli login) + simpan ke vault"
            echo ""
            echo "Workflow:"
            echo "  1. qoder-auth-swap add-account akun-a"
            echo "  2. qoder-auth-swap add-account akun-b"
            echo "  3. qoder-auth-swap use akun-a  # switch kapan saja"
            ;;
        *)
            err "Command tidak dikenal: $cmd"
            echo "  Run: qoder-auth-swap --help"
            exit 1
            ;;
    esac
}

main "$@"
